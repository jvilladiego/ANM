<?xml version="1.0" encoding="windows-1252" ?>
<persistence xmlns="http://java.sun.com/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="http://java.sun.com/xml/ns/persistence http://java.sun.com/xml/ns/persistence/persistence_2_0.xsd"
             version="2.0">
  <persistence-unit name="WebCenterContentWS">
    <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>
    <jta-data-source>jdbc/WCCConnectionDS_WS</jta-data-source>
    <class>co.gov.anm.sgd.entity.UnidadAdministrativa</class>
    <shared-cache-mode>NONE</shared-cache-mode>
    <properties>
      <property name="eclipselink.target-server" value="WebLogic_10"/>
      <property name="javax.persistence.jtaDataSource" value="jdbc/WCCConnectionDS_WS"/>
    </properties>
  </persistence-unit>
  <persistence-unit name="Comunicaciones">
    <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>
    <jta-data-source>jdbc/ComunicacionesDS</jta-data-source>
    <class>co.gov.anm.sgd.entity.SgdAnexoComunicacion</class>
    <class>co.gov.anm.sgd.entity.SgdComunicacion</class>
    <class>co.gov.anm.sgd.entity.SgdInteresado</class>
    <class>co.gov.anm.sgd.entity.SgdRol</class>
    <class>co.gov.anm.sgd.entity.SgdUsuario</class>
    <class>co.gov.anm.sgd.entity.SgdUsuarioRol</class>
    <class>co.gov.anm.sgd.entity.Subcategoria</class>
    <class>co.gov.anm.sgd.entity.TipoSolicitud</class>
    <class>co.gov.anm.sgd.entity.TipoSolicitante</class>
    <shared-cache-mode>NONE</shared-cache-mode>
    <properties>
      <property name="eclipselink.target-server" value="WebLogic_10"/>
      <property name="javax.persistence.jtaDataSource" value="jdbc/ComunicacionesDS"/>
    </properties>
  </persistence-unit>
</persistence>
