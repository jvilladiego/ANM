<?xml version='1.0' encoding='UTF-8'?>
<jsp:root xmlns:jsp="http://java.sun.com/JSP/Page" version="2.1" xmlns:f="http://java.sun.com/jsf/core"
          xmlns:af="http://xmlns.oracle.com/adf/faces/rich">
    <jsp:directive.page contentType="text/html;charset=UTF-8"/>
    <f:view xmlns:c="http://java.sun.com/jsp/jstl/core" xmlns:trh="http://myfaces.apache.org/trinidad/html"
            xmlns:wf="http://xmlns.oracle.com/bpel/workflow/workflow-taglib.tld"
            xmlns:wlc="http://xmlns.oracle.com/bpel/workflow/worklist">
        <af:document title="CrearComunicacionRespuestaHT_TaskDetails.jspx" id="d1">
            <af:messages id="m1"/>
            <af:resource type="javascript" source="/jsLibs/taskDetails.js"/>
            <af:resource type="javascript" source="/jsLibs/commonBPM.js"/>
            <af:form id="f1" usesUpload="true">
                <af:panelGroupLayout layout="vertical" inlineStyle="padding: 5px;" id="pgl15">
                    <af:panelHeader text="#{bindings.title.inputValue}" id="ph1">
                        <f:facet name="info"/>
                        <f:facet name="legend"/>
                        <f:facet name="menuBar"/>
                        <f:facet name="toolbar">
                            <af:toolbar visible="#{actionAvailable.toolbarAvailable}" id="t2">
                                <af:switcher id="customActionButtons"
                                             facetName="#{actionAvailable.isCustomActionButtons}">
                                    <f:facet name="true">
                                        <af:panelGroupLayout layout="horizontal" id="pgl13">
                                            <af:button actionListener="#{CrearComunicacionRespuestaJSFBean.crearComunicacion}"
                                                       text="#{wf:getResourceValue('ACCEPT', 'bindings.customActions')}"
                                                       disabled="#{!bindings.ACCEPT.enabled}"
                                                       action="#{invokeActionBean.invokeOperation}"
                                                       partialSubmit="false"
                                                       visible="#{wf:isCustomActionAvailable('ACCEPT', 'bindings.customActions')}"
                                                       id="b5">
                                                <f:attribute name="DC_OPERATION_BINDING" value="bindings.ACCEPT"/>
                                            </af:button>
                                        </af:panelGroupLayout>
                                    </f:facet>
                                </af:switcher>
                                <af:button actionListener="#{invokeActionBean.setOperation}" text="#{resources.CLAIM}"
                                           id="Claim" action="#{invokeActionBean.invokeOperation}" partialSubmit="false"
                                           visible="#{actionAvailable.claimAvailable}">
                                    <f:attribute name="DC_OPERATION_BINDING" value="bindings.Claim"/>
                                </af:button>
                                <af:button id="acknowledge" actionListener="#{invokeActionBean.setOperation}"
                                           text="#{resources.ACKNOWLEDGE}" action="#{invokeActionBean.invokeOperation}"
                                           partialSubmit="false" visible="#{actionAvailable.isFyiTask}">
                                    <f:attribute name="DC_OPERATION_BINDING" value="bindings.Acknowledge"/>
                                </af:button>
                                <af:button id="resume" actionListener="#{invokeActionBean.setOperation}"
                                           text="#{resources.RESUME}" action="#{invokeActionBean.invokeOperation}"
                                           partialSubmit="false" visible="#{actionAvailable.resumeAvailable}">
                                    <f:attribute name="DC_OPERATION_BINDING" value="bindings.Resume"/>
                                </af:button>
                                <af:panelGroupLayout layout="horizontal" id="pgl25" visible="false">
                                    <af:group rendered="#{!((empty actionAvailable.customActions) and (empty actionAvailable.redirectActions) and (empty actionAvailable.otherActions)) || bindings.update.enabled}"
                                              id="g6">
                                        <af:menuBar id="mb1">
                                            <af:menu id="acts" text="#{resources.TASK_ACTIONS}"
                                                     visible="#{actionAvailable.actionsAvailable || bindings.update.enabled}">
                                                <af:group id="g4">
                                                    <af:forEach var="childNode1"
                                                                items="#{actionAvailable.customActions}">
                                                        <af:commandMenuItem textAndAccessKey="#{childNode1.displayName}"
                                                                            actionListener="#{invokeActionBean.setAction}"
                                                                            action="#{invokeActionBean.action}"
                                                                            partialSubmit="false" id="cmi2">
                                                            <f:attribute name="ACTION_MENU_ITEM"
                                                                         value="#{childNode1.action}"/>
                                                        </af:commandMenuItem>
                                                    </af:forEach>
                                                </af:group>
                                                <af:group id="g2">
                                                    <af:forEach var="childNode2"
                                                                items="#{actionAvailable.redirectActions}">
                                                        <af:commandMenuItem textAndAccessKey="#{resources[childNode2]}"
                                                                            actionListener="#{invokeActionBean.setAction}"
                                                                            action="#{invokeActionBean.action}"
                                                                            partialSubmit="true" id="cmi1">
                                                            <f:attribute name="ACTION_MENU_ITEM" value="#{childNode2}"/>
                                                        </af:commandMenuItem>
                                                    </af:forEach>
                                                </af:group>
                                                <af:group id="g5">
                                                    <af:forEach var="childNode3"
                                                                items="#{actionAvailable.otherActions}">
                                                        <af:commandMenuItem textAndAccessKey="#{resources[childNode3]}"
                                                                            actionListener="#{invokeActionBean.setAction}"
                                                                            action="#{invokeActionBean.action}"
                                                                            partialSubmit="false" id="cmi4">
                                                            <f:attribute name="ACTION_MENU_ITEM" value="#{childNode3}"/>
                                                        </af:commandMenuItem>
                                                    </af:forEach>
                                                </af:group>
                                                <af:group id="g1">
                                                    <af:commandMenuItem id="save" textAndAccessKey="#{resources.SAVE}"
                                                                        actionListener="#{invokeActionBean.setAction}"
                                                                        action="#{invokeActionBean.action}"
                                                                        partialSubmit="false"
                                                                        rendered="#{actionAvailable.updateAvailable}">
                                                        <f:attribute name="ACTION_MENU_ITEM" value="bindings.update"/>
                                                    </af:commandMenuItem>
                                                </af:group>
                                            </af:menu>
                                        </af:menuBar>
                                    </af:group>
                                </af:panelGroupLayout>
                                <af:spacer width="10" id="s16"/>
                                <af:link shortDesc="#{resources.PREVIOUS_TASK}"
                                         icon="#{ adfFacesContext.rightToLeft ? '/hw_images/nexttraversalarrow_ena.png'  : '/hw_images/previoustraversalarrow_ena.png'}"
                                         action="fetchPreviousTask"
                                         visible="#{pageFlowScope.enableNavigationButton != null}" id="l2"/>
                                <af:spacer width="10" id="s4"/>
                                <af:link shortDesc="#{resources.NEXT_TASK}"
                                         icon="#{ adfFacesContext.rightToLeft ? '/hw_images/previoustraversalarrow_ena.png' : '/hw_images/nexttraversalarrow_ena.png'}"
                                         action="fetchNextTask"
                                         visible="#{pageFlowScope.enableNavigationButton != null}" id="l1"/>
                                <af:spacer width="10" id="s10"/>
                                <af:link shortDesc="#{resources.SHORT_DESC_CLOSE}" icon="/hw_images/close_ena.png"
                                         action="closeTaskFlow"
                                         visible="#{pageFlowScope.enableNavigationButton != null}" id="l3"/>
                            </af:toolbar>
                        </f:facet>
                        <f:facet name="context"/>
                        <af:panelStretchLayout id="rootPanel" styleClass="AFStretchWidth" startWidth="10%"
                                               endWidth="10%" dimensionsFrom="children">
                         
                            <f:facet name="center">
                                <af:panelGroupLayout layout="vertical" id="panelCenter" styleClass="AFStretchWidth">
                                    
                                    <af:panelBox text="Plantillas" id="pb2" >
                                        <af:table var="row" rowBandingInterval="1" id="t5"
                                                rowSelection="single" value="#{CrearComunicacionRespuestaJSFBean.lstPlantilla}">
                                            <af:column sortable="false" headerText="Nombre plantilla" 
                                                    id="c3" width="300" >
                                                <af:link text="#{row.nombre}" id="l4" targetFrame="_blank" 
                                                        destination="#{row.ruta}"/>
                                            </af:column>
                                            <af:column sortable="false" headerText="Fecha creación" id="c4">
                                                <af:outputText value="#{row.fechaCreacion}" id="ot24"/>
                                            </af:column>
                                        </af:table>
                                    </af:panelBox>
                                
                                    <af:panelBox id="pBox1" text="Comunicaci&#243;n">
                                        <af:panelFormLayout id="pflInfo12" rows="3" labelWidth="30%" maxColumns="2"
                                                            styleClass="p_AFClickToEdit" fieldWidth="40%">
                                             <af:inputText value="#{bindings.asunto.inputValue}"
                                                          label="Asunto" styleClass="AFStretchWidth"
                                                          maximumLength="500" required="true"
                                                          shortDesc="#{bindings.asunto.hints.tooltip}" id="it4">
                                                <f:validator binding="#{bindings.asunto.validator}"/>
                                                <f:validateLength maximum="500"/>
                                            </af:inputText>
                                            <af:panelLabelAndMessage label="Fecha de Radicaci&#243;n" id="plam8">
                                                <af:outputText value="#{bindings.fecRadicacion.inputValue}"
                                                               shortDesc="#{bindings.fecRadicacion.hints.tooltip}"
                                                               id="ot41">
                                                    <af:convertDateTime pattern="dd-MMM-yyyy hh:mm:ss a"/>
                                                </af:outputText>
                                            </af:panelLabelAndMessage>
                                            <af:inputText value="#{bindings.nombre6.inputValue}" columns="90"
                                                          label="Dependencia Destino" readOnly="true"
                                                          required="#{bindings.nombre6.hints.mandatory}" 
                                                          maximumLength="#{bindings.nombre6.hints.precision}"
                                                          shortDesc="#{bindings.nombre6.hints.tooltip}" id="it57">
                                                <f:validator binding="#{bindings.nombre6.validator}"/>
                                            </af:inputText>
                                            <af:panelLabelAndMessage label="Número radicado relacionado" id="plam6"
                                                    rendered="#{bindings.nroRadicadoRelacionado.inputValue != null}">
                                                 <af:link text="#{bindings.nroRadicadoRelacionado.inputValue}" targetFrame="_blank"
                                                         destination="#{bindings.urlDocumRelacionadoBO.inputValue}"
                                                          id="l5"/>
                                            </af:panelLabelAndMessage>
                                            <af:panelLabelAndMessage label="Fecha de Vencimiento" id="plam1">
                                                <af:outputText value="#{bindings.fecVencimiento.inputValue}"
                                                               shortDesc="#{bindings.fecVencimiento.hints.tooltip}"
                                                               id="ot18">
                                                    <af:convertDateTime pattern="dd-MMM-yyyy hh:mm:ss a"/>
                                                </af:outputText>
                                            </af:panelLabelAndMessage>
                                            <af:inputNumberSpinbox value="#{bindings.nroFolios.inputValue}"
                                                                   required="true"
                                                                   label="Número de Folios"
                                                                   columns="#{bindings.nroFolios.hints.displayWidth}"
                                                                   minimum="1" maximum="1000" stepSize="1"
                                                                   shortDesc="#{bindings.nroFolios.hints.tooltip}"
                                                                   id="ins1"/>
                                            <af:inputText value="#{bindings.referencia.inputValue}" simple="false"
                                                          required="#{bindings.referencia.hints.mandatory}"
                                                          label="Referencia"
                                                          columns="#{bindings.referencia.hints.displayWidth}"
                                                          maximumLength="200"
                                                          shortDesc="#{bindings.referencia.hints.tooltip}" id="it3">
                                                <f:validateLength maximum="200"/>
                                            </af:inputText>
                                            <af:panelLabelAndMessage label="Expediente Minero Relacionado" id="plam58">
                                                <af:outputText value="#{bindings.esTituloMinero.inputValue == true? 'SI' : 'NO'}"
                                                           shortDesc="#{bindings.esTituloMinero.hints.tooltip}"
                                                           id="ot55"/>
                                            </af:panelLabelAndMessage>
                                            <af:panelLabelAndMessage label="N&#250;mero de Placa" id="plam32">
                                                <af:outputText value="#{bindings.nroPlaca.inputValue}"
                                                           shortDesc="#{bindings.nroPlaca.hints.tooltip}" id="ot90"/>
                                            </af:panelLabelAndMessage>
                                        </af:panelFormLayout>
                                    </af:panelBox>
                                    <af:panelBox id="pbAdjunto" text="Adjuntos">
                                        <af:panelGroupLayout layout="vertical" id="pnlAdj1">
                                            <af:panelGroupLayout layout="horizontal" id="pnlAdj2">                                    
                                                <af:outputLabel value="Documento Principal" id="ppalLab" for="dwnLink"/>
                                                <af:link id="dwnLink" text="#{bindings.name1.inputValue}" targetFrame="_blank" 
                                                        partialTriggers="adfUpl"
                                                        immediate="true">
                                                    <af:fileDownloadActionListener method="#{CrearComunicacionRespuestaJSFBean.descargar}"/>
                                                </af:link>
                                                <af:spacer id="spAdjuntos" width="20" height="20"/>
                                                <af:inputFile label=" " id="adfUpl" autoSubmit="true"
                                                    binding="#{CrearComunicacionRespuestaJSFBean.ifAnexo}"
                                                    valueChangeListener="#{CrearComunicacionRespuestaJSFBean.cambiarDocPpal}"/>
                                            </af:panelGroupLayout>
                                            <wlc:manageDocuments docBean="#{pageFlowScope.docMgmtBean}" id="md1"
                                                                     rendered="#{!actionAvailable.inNotificationClient}"/>
                                        </af:panelGroupLayout>                                        
                                    </af:panelBox>
                                    <!--af:inputText value="#{bindings.instanceId.inputValue}"
                                                  label="#{bindings.instanceId.hints.label}"
                                                  required="#{bindings.instanceId.hints.mandatory}"
                                                  columns="#{bindings.instanceId.hints.displayWidth}"
                                                  maximumLength="#{bindings.instanceId.hints.precision}"
                                                  shortDesc="#{bindings.instanceId.hints.tooltip}" id="it5">
                                        <f:validator binding="#{bindings.instanceId.validator}"/>
                                    </af:inputText>
                                    <af:panelFormLayout id="pfl2">
                                        <af:inputText value="#{bindings.name1.inputValue}"
                                                      label="#{bindings.name1.hints.label}"
                                                      required="#{bindings.name1.hints.mandatory}"
                                                      columns="#{bindings.name1.hints.displayWidth}"
                                                      maximumLength="#{bindings.name1.hints.precision}"
                                                      shortDesc="#{bindings.name1.hints.tooltip}" id="it5">
                                            <f:validator binding="#{bindings.name1.validator}"/>
                                        </af:inputText>
                                        <af:inputText value="#{bindings.content1.inputValue}"
                                                      label="#{bindings.content1.hints.label}"
                                                      required="#{bindings.content1.hints.mandatory}"
                                                      columns="#{bindings.content1.hints.displayWidth}"
                                                      maximumLength="#{bindings.content1.hints.precision}"
                                                      shortDesc="#{bindings.content1.hints.tooltip}" id="it8">
                                            <f:validator binding="#{bindings.content1.validator}"/>
                                        </af:inputText>
                                        <af:inputText value="#{bindings.mimetype.inputValue}"
                                                      label="#{bindings.mimetype.hints.label}"
                                                      required="#{bindings.mimetype.hints.mandatory}"
                                                      columns="#{bindings.mimetype.hints.displayWidth}"
                                                      maximumLength="#{bindings.mimetype.hints.precision}"
                                                      shortDesc="#{bindings.mimetype.hints.tooltip}" id="it9">
                                            <f:validator binding="#{bindings.mimetype.validator}"/>
                                        </af:inputText>
                                        <af:inputText value="#{bindings.size.inputValue}"
                                                      label="#{bindings.size.hints.label}"
                                                      required="#{bindings.size.hints.mandatory}"
                                                      columns="#{bindings.size.hints.displayWidth}"
                                                      maximumLength="#{bindings.size.hints.precision}"
                                                      shortDesc="#{bindings.size.hints.tooltip}" id="it10">
                                            <f:validator binding="#{bindings.size.validator}"/>
                                            <af:convertNumber groupingUsed="false" pattern="#{bindings.size.format}"/>
                                        </af:inputText>
                                        <af:inputText value="#{bindings.linkDocPrincipal.inputValue}"
                                                      label="#{bindings.linkDocPrincipal.hints.label}"
                                                      required="#{bindings.linkDocPrincipal.hints.mandatory}"
                                                      columns="#{bindings.linkDocPrincipal.hints.displayWidth}"
                                                      maximumLength="#{bindings.linkDocPrincipal.hints.precision}"
                                                      shortDesc="#{bindings.linkDocPrincipal.hints.tooltip}" id="it11">
                                            <f:validator binding="#{bindings.linkDocPrincipal.validator}"/>
                                        </af:inputText>
                                    </af:panelFormLayout-->
                                    <af:panelBox id="pBox2" text="Gestión Documental"
                                                rendered="#{!bindings.esTituloMinero.inputValue}">
                                        <af:panelFormLayout id="tab1Form1">
                                            <af:selectOneChoice id="selectCatProceso"
                                                                showRequired="#{!bindings.esTituloMinero.inputValue}"
                                                                disabled="#{bindings.esTituloMinero.inputValue}"
                                                                shortDesc="#{bindings.idCatProceso.hints.tooltip}"
                                                                autoSubmit="true" clientComponent="true"
                                                                label="Categoría"
                                                                partialTriggers="ot55"
                                                                valueChangeListener="#{CrearComunicacionRespuestaJSFBean.cambiarCategoriaProceso}"
                                                                value="#{bindings.idCatProceso.inputValue}">
                                                <f:selectItem itemLabel="Seleccione" id="selCPItm1"/>
                                                <f:selectItems value="#{CrearComunicacionRespuestaJSFBean.categoriasProceso}"
                                                               id="selCPItm2"/>
                                            </af:selectOneChoice>
                                            <af:selectOneChoice id="selectProceso"                                                                        
                                                                shortDesc="#{bindings.idProceso.hints.tooltip}"
                                                                autoSubmit="true" clientComponent="true"
                                                                showRequired="#{!bindings.esTituloMinero.inputValue}"
                                                                disabled="#{bindings.esTituloMinero.inputValue}"
                                                                label="Proceso"
                                                                partialTriggers="ot55 selectCatProceso"
                                                                valueChangeListener="#{CrearComunicacionRespuestaJSFBean.cambiarProceso}"
                                                                value="#{bindings.idProceso.inputValue}">
                                                <f:selectItem itemLabel="Seleccione" id="selPRItm1"/>
                                                <f:selectItems value="#{CrearComunicacionRespuestaJSFBean.procesos}"
                                                               id="selPRItm2"/>
                                            </af:selectOneChoice>
                                            <af:selectOneChoice id="selectSerie"
                                                                shortDesc="#{bindings.idSerie.hints.tooltip}"
                                                                autoSubmit="true" clientComponent="true"
                                                                showRequired="#{!bindings.esTituloMinero.inputValue}"
                                                                disabled="#{bindings.esTituloMinero.inputValue}"
                                                                label="Serie"
                                                                partialTriggers="ot55 selectCatProceso selectProceso"
                                                                valueChangeListener="#{CrearComunicacionRespuestaJSFBean.cambiarSerie}"
                                                                value="#{bindings.idSerie.inputValue}">
                                                <f:selectItem itemLabel="Seleccione" id="selSRItm1"/>
                                                <f:selectItems value="#{CrearComunicacionRespuestaJSFBean.series}"
                                                               id="selSRItm2"/>
                                            </af:selectOneChoice>
                                            <af:selectOneChoice id="selectSubSerie"
                                                                shortDesc="#{bindings.idSubSerie.hints.tooltip}"
                                                                autoSubmit="true" clientComponent="true"
                                                                disabled="#{bindings.esTituloMinero.inputValue}"
                                                                label="Subserie"
                                                                partialTriggers="ot55 selectCatProceso selectProceso selectSerie"
                                                                valueChangeListener="#{CrearComunicacionRespuestaJSFBean.cambiarSubSerie}"
                                                                value="#{bindings.idSubSerie.inputValue}">
                                                <f:selectItem itemLabel="Seleccione" id="selSSRItm1"/>
                                                <f:selectItems value="#{CrearComunicacionRespuestaJSFBean.subseries}"
                                                               id="selSSRItm2"/>
                                            </af:selectOneChoice>
                                            <af:selectOneChoice id="selectCuaderno"
                                                                shortDesc="#{bindings.idCuaderno.hints.tooltip}"
                                                                label="Expediente"
                                                                autoSubmit="true" clientComponent="true"
                                                                disabled="#{bindings.esTituloMinero.inputValue}"
                                                                partialTriggers="ot55 selectCatProceso selectProceso selectSerie selectSubSerie"
                                                                valueChangeListener="#{CrearComunicacionRespuestaJSFBean.cambiarCuaderno}"
                                                                value="#{bindings.idCuaderno.inputValue}">
                                                <f:selectItem itemLabel="Seleccione" id="selCuaItm1"/>
                                                <f:selectItems value="#{CrearComunicacionRespuestaJSFBean.cuadernos}"
                                                               id="selCuaItm2"/>
                                            </af:selectOneChoice>
                                        </af:panelFormLayout>
                                    </af:panelBox>
                                    <af:panelBox id="pb3" text="Gestión Documental"
                                            rendered="#{bindings.esTituloMinero.inputValue}">
                                        <af:panelFormLayout id="tab2Form1">
                                            <af:selectOneChoice id="selectTramite"
                                                                shortDesc="#{bindings.idTramite.hints.tooltip}"
                                                                showRequired="#{bindings.esTituloMinero.inputValue}"
                                                                disabled="#{!bindings.esTituloMinero.inputValue}"
                                                                label="Tr&#225;mite" autoSubmit="true"
                                                                clientComponent="true"
                                                                valueChangeListener="#{CrearComunicacionRespuestaJSFBean.cambiarTramite}"
                                                                value="#{bindings.idTramite.inputValue}">
                                                <f:selectItem itemLabel="Seleccione" id="selTramite1"/>
                                                <f:selectItems value="#{CrearComunicacionRespuestaJSFBean.tramites}"
                                                               id="selTramites2"/>
                                            </af:selectOneChoice>
                                            <af:selectOneChoice id="selectTpDocumento"
                                                                shortDesc="#{bindings.idTpDocumento.hints.tooltip}"
                                                                showRequired="#{bindings.esTituloMinero.inputValue}"
                                                                disabled="#{!bindings.esTituloMinero.inputValue}"
                                                                label="Tipo Documental"
                                                                autoSubmit="true" clientComponent="true"
                                                                partialTriggers="selectTramite"
                                                                valueChangeListener="#{CrearComunicacionRespuestaJSFBean.cambiarTipoDocumento}"
                                                                value="#{bindings.idTpDocumento.inputValue}">        
                                                <f:selectItem itemLabel="Seleccione" id="selTipoDoc"/>                                                                        
                                                <f:selectItems value="#{CrearComunicacionRespuestaJSFBean.tiposDocumentales}"
                                                               id="selTpDoc2"/>
                                            </af:selectOneChoice>
                                        </af:panelFormLayout>
                                    </af:panelBox>
                                    
                                    <af:panelGroupLayout id="pgl1">
                                        <af:showDetailHeader size="2" text="#{resources.COMMENTS}"
                                                             disclosed="#{actionAvailable.discloseComments}"
                                                             contentStyle="padding: 5px;"
                                                             partialTriggers="commentSubmit" id="sdh1">
                                            <af:panelGroupLayout layout="vertical" inlineStyle="padding:10px;"
                                                                 id="pgl2">
                                                <af:inputText id="cmtBox" rows="2" columns="80" wrap="off"
                                                              partialTriggers="commentSubmit"
                                                              value="#{commentBean.value}"
                                                              visible="#{actionAvailable.isCommentUpdatable}"
                                                              maximumLength="2000" label=""
                                                              inlineStyle="text-align:left;"/>
                                                <af:spacer height="5" rendered="#{actionAvailable.isCommentUpdatable}"
                                                           id="s1"/>
                                                <af:toolbar rendered="#{actionAvailable.isCommentUpdatable}" id="t1">
                                                    <af:commandButton id="commentSubmit"
                                                                      text="#{resources.POST_COMMENT}"
                                                                      partialSubmit="true"
                                                                      actionListener="#{bindings.CreateInsert1.execute}"
                                                                      action="#{commentBean.addComment}"/>
                                                </af:toolbar>
                                                <af:spacer height="10" id="dc_s7"
                                                           rendered="#{actionAvailable.isCommentUpdatable}"/>
                                                <af:outputText value="#{resources.NO_ROWS_YET}"
                                                               rendered="#{(actionAvailable.isCommentUpdatable) and (empty bindings.userComment)}"
                                                               id="ot1"/>
                                                <af:forEach items="#{bindings.userComment.children}" var="row">
                                                    <af:panelGroupLayout id="pgl9" layout="horizontal" valign="top">
                                                        <af:image source="/images/simple_16x16.png" id="i19"/>
                                                        <af:spacer width="10" height="10" id="s27"/>
                                                        <af:panelGroupLayout id="pgl19" layout="vertical">
                                                            <af:panelGroupLayout id="pgl69" layout="horizontal">
                                                                <af:switcher facetName="#{row.updatedBy.displayName != null}"
                                                                             id="s17">
                                                                    <f:facet name="true">
                                                                        <af:group id="g12">
                                                                            <af:outputText value="#{row.updatedBy.displayName}"
                                                                                           id="ot59"
                                                                                           inlineStyle="font-weight:bold;"/>
                                                                            <af:spacer width="10" height="10"
                                                                                       id="s129"/>
                                                                            <af:outputText value="#{row.updatedDate}"
                                                                                           id="ot119"
                                                                                           inlineStyle="font-size:x-small; color:Gray;">
                                                                                <f:converter converterId="dateTimeConvertor"/>
                                                                            </af:outputText>
                                                                        </af:group>
                                                                    </f:facet>
                                                                    <f:facet name="false">
                                                                        <af:group id="g11">
                                                                            <af:outputText value="#{pageFlowScope.ADFHumanTaskBean.workflowContext.user}"
                                                                                           inlineStyle="font-weight:bold;"
                                                                                           id="ot15"/>
                                                                            <af:spacer width="10" height="10" id="s32"/>
                                                                            <af:outputText value="#{resources.TODAY}"
                                                                                           id="ot12"/>
                                                                        </af:group>
                                                                    </f:facet>
                                                                </af:switcher>
                                                            </af:panelGroupLayout>
                                                            <af:outputText value="#{row.comment}" id="ot419"/>
                                                            <af:spacer width="10" height="5" id="s59"/>
                                                        </af:panelGroupLayout>
                                                    </af:panelGroupLayout>
                                                </af:forEach>
                                            </af:panelGroupLayout>
