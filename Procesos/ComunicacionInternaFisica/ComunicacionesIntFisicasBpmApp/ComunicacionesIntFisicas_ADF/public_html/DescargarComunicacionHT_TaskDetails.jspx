<?xml version='1.0' encoding='UTF-8'?>
<jsp:root xmlns:jsp="http://java.sun.com/JSP/Page" version="2.1" xmlns:f="http://java.sun.com/jsf/core"
          xmlns:af="http://xmlns.oracle.com/adf/faces/rich">
    <jsp:directive.page contentType="text/html;charset=UTF-8"/>
    <f:view xmlns:c="http://java.sun.com/jsp/jstl/core" xmlns:trh="http://myfaces.apache.org/trinidad/html"
            xmlns:wf="http://xmlns.oracle.com/bpel/workflow/workflow-taglib.tld"
            xmlns:wlc="http://xmlns.oracle.com/bpel/workflow/worklist">
        <af:document title="DescargarComunicacionHT_TaskDetails.jspx" id="d1">
            <af:messages id="m1"/>
            <af:resource type="javascript" source="/jsLibs/taskDetails.js"/>
            <af:resource type="javascript" source="/jsLibs/commonBPM.js"/>
            <af:form id="f1" usesUpload="true">
                <af:panelGroupLayout layout="vertical" inlineStyle="padding: 5px;" id="pgl1">
                    <af:panelHeader text="#{bindings.title.inputValue}" id="ph1">
                        <f:facet name="info"/>
                        <f:facet name="legend"/>
                        <f:facet name="menuBar"/>
                        <f:facet name="toolbar">
                            <af:toolbar visible="#{actionAvailable.toolbarAvailable}" id="t1">
                                <af:switcher id="customActionButtons"
                                             facetName="#{actionAvailable.isCustomActionButtons}">
                                    <f:facet name="true">
                                        <af:panelGroupLayout layout="horizontal" id="pgl2">
                                            <af:button id="btn_aceptar" text="Aceptar">
                                                <af:showPopupBehavior popupId="popup_accept"/>
                                            </af:button>
                                            <af:popup childCreation="deferred" autoCancel="disabled" id="popup_accept">
                                                <af:dialog title="Mensaje" id="d3" type="cancel">
                                                   
                                                    <af:panelGroupLayout layout="vertical" id="pgl5" halign="center">
                                                        <af:outputText id="ot_mensaje"
                                                                   value="&#191;Esta seguro que desea cerrar esta actividad?"/>
                                                        <af:spacer width="10" height="10" id="s19"/>
                                                        <af:outputText id="ot18"
                                                                   value="Recuerde que previamente tuvo que haber descargado el documento principal."/>
                                                        <af:spacer width="10" height="10" id="s20"/>
                                                        
                                                    </af:panelGroupLayout>
                                                     <f:facet name="buttonBar">
                                                        <af:button actionListener="#{invokeActionBean.setOperation}"
                                                                   text="#{wf:getResourceValue('OK', 'bindings.customActions')}"
                                                                   disabled="#{!bindings.OK.enabled}"
                                                                   action="#{invokeActionBean.invokeOperation}"
                                                                   partialSubmit="false"
                                                                   visible="#{wf:isCustomActionAvailable('OK', 'bindings.customActions')}"
                                                                   id="b1">
                                                            <f:attribute name="DC_OPERATION_BINDING" value="bindings.OK"/>
                                                        </af:button>
                                                    </f:facet>
                                                </af:dialog>
                                            </af:popup>
                                            <!--
                                            <af:button actionListener="#{invokeActionBean.setOperation}"
                                                       text="#{wf:getResourceValue('OK', 'bindings.customActions')}"
                                                       disabled="#{!bindings.OK.enabled}"
                                                       action="#{invokeActionBean.invokeOperation}"
                                                       partialSubmit="false"
                                                       visible="#{wf:isCustomActionAvailable('OK', 'bindings.customActions')}"
                                                       id="b1">
                                                <f:attribute name="DC_OPERATION_BINDING" value="bindings.OK"/>
                                            </af:button>
                                            -->
                                        </af:panelGroupLayout>
                                    </f:facet>
                                </af:switcher>
                                <af:button actionListener="#{invokeActionBean.setOperation}" text="#{resources.CLAIM}"
                                           id="Claim" action="#{invokeActionBean.invokeOperation}" partialSubmit="false"
                                           visible="#{actionAvailable.claimAvailable}">
                                    <f:attribute name="DC_OPERATION_BINDING" value="bindings.Claim"/>
                                </af:button>
                                <af:button id="acknowledge" actionListener="#{invokeActionBean.setOperation}"
                                           text="#{resources.ACKNOWLEDGE}" action="#{invokeActionBean.invokeOperation}"
                                           partialSubmit="false" visible="#{actionAvailable.isFyiTask}">
                                    <f:attribute name="DC_OPERATION_BINDING" value="bindings.Acknowledge"/>
                                </af:button>
                                <af:button id="resume" actionListener="#{invokeActionBean.setOperation}"
                                           text="#{resources.RESUME}" action="#{invokeActionBean.invokeOperation}"
                                           partialSubmit="false" visible="#{actionAvailable.resumeAvailable}">
                                    <f:attribute name="DC_OPERATION_BINDING" value="bindings.Resume"/>
                                </af:button>
                                <af:panelGroupLayout layout="horizontal" id="pgl3" visible="false">
                                    <af:group rendered="#{!((empty actionAvailable.customActions) and (empty actionAvailable.redirectActions) and (empty actionAvailable.otherActions)) || bindings.update.enabled}"
                                              id="g1">
                                        <af:menuBar id="mb1">
                                            <af:menu id="acts" text="#{resources.TASK_ACTIONS}"
                                                     visible="#{actionAvailable.actionsAvailable || bindings.update.enabled}">
                                                <af:group id="g2">
                                                    <af:forEach var="childNode1"
                                                                items="#{actionAvailable.customActions}">
                                                        <af:commandMenuItem textAndAccessKey="#{childNode1.displayName}"
                                                                            actionListener="#{invokeActionBean.setAction}"
                                                                            action="#{invokeActionBean.action}"
                                                                            partialSubmit="false" id="cmi2">
                                                            <f:attribute name="ACTION_MENU_ITEM"
                                                                         value="#{childNode1.action}"/>
                                                        </af:commandMenuItem>
                                                    </af:forEach>
                                                </af:group>
                                                <af:group id="g3">
                                                    <af:forEach var="childNode2"
                                                                items="#{actionAvailable.redirectActions}">
                                                        <af:commandMenuItem textAndAccessKey="#{resources[childNode2]}"
                                                                            actionListener="#{invokeActionBean.setAction}"
                                                                            action="#{invokeActionBean.action}"
                                                                            partialSubmit="true" id="cmi1">
                                                            <f:attribute name="ACTION_MENU_ITEM" value="#{childNode2}"/>
                                                        </af:commandMenuItem>
                                                    </af:forEach>
                                                </af:group>
                                                <af:group id="g4">
                                                    <af:forEach var="childNode3"
                                                                items="#{actionAvailable.otherActions}">
                                                        <af:commandMenuItem textAndAccessKey="#{resources[childNode3]}"
                                                                            actionListener="#{invokeActionBean.setAction}"
                                                                            action="#{invokeActionBean.action}"
                                                                            partialSubmit="false" id="cmi4">
                                                            <f:attribute name="ACTION_MENU_ITEM" value="#{childNode3}"/>
                                                        </af:commandMenuItem>
                                                    </af:forEach>
                                                </af:group>
                                                <af:group id="g5">
                                                    <af:commandMenuItem id="save" textAndAccessKey="#{resources.SAVE}"
                                                                        actionListener="#{invokeActionBean.setAction}"
                                                                        action="#{invokeActionBean.action}"
                                                                        partialSubmit="false"
                                                                        rendered="#{actionAvailable.updateAvailable}">
                                                        <f:attribute name="ACTION_MENU_ITEM" value="bindings.update"/>
                                                    </af:commandMenuItem>
                                                </af:group>
                                            </af:menu>
                                        </af:menuBar>
                                    </af:group>
                                </af:panelGroupLayout>
                                <af:spacer width="10" id="s1"/>
                                <af:link shortDesc="#{resources.PREVIOUS_TASK}"
                                         icon="#{ adfFacesContext.rightToLeft ? '/hw_images/nexttraversalarrow_ena.png'  : '/hw_images/previoustraversalarrow_ena.png'}"
                                         action="fetchPreviousTask"
                                         visible="#{pageFlowScope.enableNavigationButton != null}" id="l1"/>
                                <af:spacer width="10" id="s2"/>
                                <af:link shortDesc="#{resources.NEXT_TASK}"
                                         icon="#{ adfFacesContext.rightToLeft ? '/hw_images/previoustraversalarrow_ena.png' : '/hw_images/nexttraversalarrow_ena.png'}"
                                         action="fetchNextTask"
                                         visible="#{pageFlowScope.enableNavigationButton != null}" id="l2"/>
                                <af:spacer width="10" id="s3"/>
                                <af:link shortDesc="#{resources.SHORT_DESC_CLOSE}" icon="/hw_images/close_ena.png"
                                         action="closeTaskFlow"
                                         visible="#{pageFlowScope.enableNavigationButton != null}" id="l3"/>
                            </af:toolbar>
                        </f:facet>
                        <f:facet name="context"/>
                        <af:panelGroupLayout layout="vertical" id="pgl4">
                            <f:facet name="separator">
                                <af:spacer width="15" height="15" id="s4"/>
                            </f:facet>
                            <af:showDetailHeader size="2" id="dtHead" text="#{resources.DETAILS}"
                                                 shortDesc="#{resources.TASK_HEADER}"
                                                 icon="/hw_images/singleapprover_35x35.png"
                                                 disclosed="#{actionAvailable.discloseHeader}">
                                <f:facet name="context">
                                    <af:link icon="/hw_images/info.png" id="button" clientComponent="true"
                                             rendered="#{!empty bindings.activityId.inputValue}">
                                        <af:showPopupBehavior popupId="helpPopup" align="afterEnd" alignId="button"/>
                                    </af:link>
                                </f:facet>
                                <f:facet name="toolbar"/>
                                <af:panelFormLayout maxColumns="2" rows="4" id="pfl1">
                                    <af:switcher facetName="#{bindings.taskViewContext == 'FYI'}" id="s5">
                                        <f:facet name="false">
                                            <af:panelLabelAndMessage id="assignees" label="#{resources.ASSIGNEES}">
                                                <af:iterator var="assignees" varStatus="varS"
                                                             value="#{bindings.assignees.collectionModel}" id="i1">
                                                    <af:switcher facetName="#{varS.index == 0}" id="s6">
                                                        <f:facet name="false">
                                                            <af:outputText value=", " id="ot1"/>
                                                        </f:facet>
                                                    </af:switcher>
                                                    <af:switcher facetName="#{!empty assignees.displayName}" id="s7">
                                                        <f:facet name="true">
                                                            <af:outputText value="#{assignees.displayName}" id="ot2"/>
                                                        </f:facet>
                                                        <f:facet name="false">
                                                            <af:outputText value="#{assignees.id}" id="ot3"/>
                                                        </f:facet>
                                                    </af:switcher>
                                                </af:iterator>
                                            </af:panelLabelAndMessage>
                                        </f:facet>
                                    </af:switcher>
                                    <af:panelLabelAndMessage id="creator" label="#{resources.CREATOR}">
                                        <af:outputText value="#{bindings.creatorDisplayName.inputValue}" id="ot4"/>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="createdDate" label="#{resources.CREATE_DATE}">
                                        <af:outputText value="#{bindings.createdDate.inputValue}" noWrap="true"
                                                       id="ot5">
                                            <f:convertDateTime type="#{pageFlowScope.dt}" timeZone="#{pageFlowScope.tz}"
                                                               dateStyle="#{pageFlowScope.df}"
                                                               timeStyle="#{pageFlowScope.tf}"
                                                               pattern="#{pageFlowScope.dateTimePattern}"/>
                                        </af:outputText>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="updatedDate" label="#{resources.UPDATE_DATE}">
                                        <af:outputText value="#{bindings.updatedDate.inputValue}" noWrap="true"
                                                       id="ot6">
                                            <f:convertDateTime type="#{pageFlowScope.dt}" timeZone="#{pageFlowScope.tz}"
                                                               dateStyle="#{pageFlowScope.df}"
                                                               timeStyle="#{pageFlowScope.tf}"
                                                               pattern="#{pageFlowScope.dateTimePattern}"/>
                                        </af:outputText>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="expirationDate" label="#{resources.EXPIRATION_DATE}">
                                        <af:outputText value="#{bindings.expirationDate.inputValue}" id="ot7">
                                            <f:convertDateTime type="#{pageFlowScope.dt}" timeZone="#{pageFlowScope.tz}"
                                                               dateStyle="#{pageFlowScope.df}"
                                                               timeStyle="#{pageFlowScope.tf}"
                                                               pattern="#{pageFlowScope.dateTimePattern}"/>
                                        </af:outputText>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="acquiredBy" label="#{resources.ACQUIRED_BY}">
                                        <af:switcher facetName="#{!empty bindings.acquiredByDisplayName.inputValue}"
                                                     id="s8">
                                            <f:facet name="true">
                                                <af:outputText value="#{bindings.acquiredByDisplayName.inputValue}"
                                                               id="ot8"/>
                                            </f:facet>
                                            <f:facet name="false">
                                                <af:outputText value="#{bindings.acquiredBy.inputValue}" id="ot9"/>
                                            </f:facet>
                                        </af:switcher>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="dueDate" label="#{resources.DUE_DATE}"
                                                             rendered="#{!empty bindings.dueDate.inputValue}">
                                        <af:outputText value="#{bindings.dueDate.inputValue}" noWrap="true" id="ot10">
                                            <f:convertDateTime type="#{pageFlowScope.dt}" timeZone="#{pageFlowScope.tz}"
                                                               dateStyle="#{pageFlowScope.df}"
                                                               timeStyle="#{pageFlowScope.tf}"
                                                               pattern="#{pageFlowScope.dateTimePattern}"/>
                                        </af:outputText>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="outcome" label="#{resources.OUTCOME}"
                                                             rendered="#{!empty bindings.actionDisplayName.inputValue}">
                                        <af:outputText value="#{bindings.actionDisplayName.inputValue}" id="ot11"/>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="taskNumber" label="#{resources.TASK_NUMBER}">
                                        <af:outputText value="#{bindings.taskNumber.inputValue}" id="ot12"/>
                                    </af:panelLabelAndMessage>
                                    <af:inputText id="priority" value="#{bindings.priority.inputValue}"
                                                  label="#{resources.PRIORITY}"
                                                  required="#{bindings.priority.mandatory}" columns="3"
                                                  validator="#{actionAvailable.validatePriorityValue}"/>
                                    <af:panelLabelAndMessage id="state" label="#{resources.STATE}">
                                        <af:outputText value="#{resources[bindings.state.inputValue]}" id="ot13"/>
                                    </af:panelLabelAndMessage>
                                </af:panelFormLayout>
                            </af:showDetailHeader>
                            <af:showDetailHeader size="2" id="apCntHd" text="#{resources.CONTENTS}"
                                                 disclosed="#{actionAvailable.discloseContents}">
                                <af:panelGroupLayout id="plPnl76" layout="vertical" shortDesc="#{resources.CONTENTS}">
                                    <af:panelBox id="pBox1" text="Comunicaci&#243;n">
                                        <af:panelFormLayout id="pfl11" rows="4" maxColumns="3">
                                            <af:panelLabelAndMessage label="#{bindings.asunto.hints.label}" id="plam16">
                                                <af:outputText value="#{bindings.asunto.inputValue}"
                                                               shortDesc="#{bindings.asunto.hints.tooltip}" id="ot93"/>
                                            </af:panelLabelAndMessage>
                                            <af:panelLabelAndMessage label="N&#250;mero de Radicado" id="plam09">
                                                <af:outputText value="#{bindings.nroRadicado.inputValue}"
                                                               shortDesc="#{bindings.nroRadicado.hints.tooltip}"
                                                               id="ot410"></af:outputText>
                                            </af:panelLabelAndMessage>
                                            <af:panelLabelAndMessage label="Fecha de Radicaci&#243;n" id="plam8">
                                                <af:outputText value="#{bindings.fecRadicacion.inputValue}"
                                                               shortDesc="#{bindings.fecRadicacion.hints.tooltip}"
                                                               id="ot41">
                                                    <af:convertDateTime pattern="dd-MMM-yyyy hh:mm:ss a"/>
                                                </af:outputText>
                                            </af:panelLabelAndMessage>
                                            <af:panelLabelAndMessage label="N&#250;mero Radicado Relacionado"
                                                                     id="plam51" rendered="#{bindings.nroRadicadoRelacionado.inputValue != null}">
                                                <af:link text="#{bindings.nroRadicadoRelacionado.inputValue}" targetFrame="_blank"
                                                         destination="#{bindings.urlDocumRelacionadoBO.inputValue}" id="l4"/>
                                            </af:panelLabelAndMessage>
                                            <!--af:inputText value="#{bindings.urlDocumRelacionadoBO.inputValue}"
                                                          label="#{bindings.urlDocumRelacionadoBO.hints.label}"
                                                          required="#{bindings.urlDocumRelacionadoBO.hints.mandatory}"
                                                          columns="#{bindings.urlDocumRelacionadoBO.hints.displayWidth}"
                                                          maximumLength="#{bindings.urlDocumRelacionadoBO.hints.precision}"
                                                          shortDesc="#{bindings.urlDocumRelacionadoBO.hints.tooltip}"
                                                          id="it2">
                                                <f:validator binding="#{bindings.urlDocumRelacionadoBO.validator}"/>
                                            </af:inputText-->
                                            <af:panelLabelAndMessage label="Dependencia Destino" id="plam21">
                                                <af:outputText value="#{bindings.nombreDepDestino.inputValue}"
                                                               shortDesc="#{bindings.nombreDepDestino.hints.tooltip}"
                                                               id="ot42"/>
                                            </af:panelLabelAndMessage>
                                            <af:panelLabelAndMessage label="Usuario Destino" id="plam5">
                                                <af:outputText value="#{bindings.nombreUsuarioCom.inputValue}"
                                                               shortDesc="#{bindings.nombreUsuarioCom.hints.tooltip}"
                                                               id="ot17"/>
                                            </af:panelLabelAndMessage>
                                            <af:panelLabelAndMessage label="Responder Comunicacion" id="plam1">
                                                <af:outputText value="#{bindings.responderComunicacion.inputValue == true? 'SI' : 'NO'}"
                                                               shortDesc="#{bindings.responderComunicacion.hints.tooltip}"
                                                               id="ot14"/>
                                            </af:panelLabelAndMessage>
                                            <af:panelLabelAndMessage label="D&#237;as de Respuesta" id="plam2">
                                                <af:outputText value="#{bindings.tiempoRespuesta.inputValue}"
                                                               shortDesc="#{bindings.tiempoRespuesta.hints.tooltip}"
                                                               id="ot16"/>
                                            </af:panelLabelAndMessage>
                                            <af:panelLabelAndMessage label="Fecha de Vencimiento" id="plam3">
                                                <af:outputText value="#{bindings.fecVencimiento.inputValue}"
                                                               shortDesc="#{bindings.fecVencimiento.hints.tooltip}"
                                                               id="ot15">
                                                    <af:convertDateTime pattern="dd-MMM-yyyy hh:mm:ss a"/>
                                                </af:outputText>
                                            </af:panelLabelAndMessage>
                                            <af:panelLabelAndMessage label="Referencia" id="plam44">
                                                <af:outputText value="#{bindings.referencia.inputValue}"
                                                               shortDesc="#{bindings.referencia.hints.tooltip}"
                                                               id="ot73"/>
                                            </af:panelLabelAndMessage>
                                            <af:panelLabelAndMessage label="N&#250;mero de Folios" id="plam60">
                                                <af:outputText value="#{bindings.nroFolios.inputValue}"
                                                               shortDesc="#{bindings.nroFolios.hints.tooltip}"
                                                               id="ot030">
                                                    <af:convertNumber groupingUsed="false"
                                                                      pattern="#{bindings.nroFolios.format}"/>
                                                </af:outputText>
                                            </af:panelLabelAndMessage>
                                            <af:panelLabelAndMessage label="Expediente Minero Relacionado" id="plam58">
                                                <af:outputText value="#{bindings.esTituloMinero.inputValue == true? 'SI' : 'NO'}"
                                                               shortDesc="#{bindings.esTituloMinero.hints.tooltip}"
                                                               id="ot55"/>
                                            </af:panelLabelAndMessage>
                                            <af:panelLabelAndMessage label="N&#250;mero de Placa" id="plam32">
                                                <af:outputText value="#{bindings.nroPlaca.inputValue}"
                                                               shortDesc="#{bindings.nroPlaca.hints.tooltip}"
                                                               id="ot90"/>
                                            </af:panelLabelAndMessage>
                                        </af:panelFormLayout>
                                    </af:panelBox>
                                </af:panelGroupLayout>
                            </af:showDetailHeader>
                            <af:panelGroupLayout id="plPnl077" layout="vertical" shortDesc="Metadatos"
                                                 inlineStyle="margin-left: 5px; margin-right: 2px;">
                                <af:panelBox id="pb1" text="Gestión Documental"
                                             rendered="#{!bindings.esTituloMinero.inputValue}">
                                    <af:panelFormLayout id="pfl011" maxColumns="1" rows="5">
                                        <af:panelLabelAndMessage label="Categor&#237;a" id="plam4">
                                            <af:outputText value="#{bindings.catProceso.inputValue}"
                                                           shortDesc="#{bindings.catProceso.hints.tooltip}"
                                                           id="ot80"/>
                                        </af:panelLabelAndMessage>
                                        <af:panelLabelAndMessage label="Proceso" id="plam29">
                                            <af:outputText value="#{bindings.proceso.inputValue}"
                                                           shortDesc="#{bindings.proceso.hints.tooltip}"
                                                           id="ot114"/>
                                        </af:panelLabelAndMessage>
                                        <af:panelLabelAndMessage label="Serie" id="plam57">
                                            <af:outputText value="#{bindings.serie.inputValue}"
                                                           shortDesc="#{bindings.serie.hints.tooltip}" id="ot50"/>
                                        </af:panelLabelAndMessage>
                                        <af:panelLabelAndMessage label="Subserie" id="plam35">
                                            <af:outputText value="#{bindings.subserie.inputValue}"
                                                           shortDesc="#{bindings.subserie.hints.tooltip}" id="ot44"></af:outputText>
                                        </af:panelLabelAndMessage>
                                        <af:panelLabelAndMessage label="Expediente" id="plam54">
                                            <af:outputText value="#{bindings.cuaderno.inputValue}"
                                                           shortDesc="#{bindings.cuaderno.hints.tooltip}"
                                                           id="ot24"/>
                                        </af:panelLabelAndMessage>
                                    </af:panelFormLayout>
                                </af:panelBox>
                                <af:panelBox id="pb2" text="Gestión Documental"
                                             rendered="#{bindings.esTituloMinero.inputValue}">
                                    <af:panelFormLayout id="pfl2" rows="2" maxColumns="1">
                                        <af:panelLabelAndMessage label="Tr&#225;mite" id="plam23">
