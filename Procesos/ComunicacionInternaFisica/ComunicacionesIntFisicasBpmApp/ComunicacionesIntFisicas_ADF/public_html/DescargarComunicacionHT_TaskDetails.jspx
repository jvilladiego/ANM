                                </af:panelBox>
                            </af:panelGroupLayout>
                            <af:showDetailHeader size="2" id="sdh2" disclosed="true" text="Adjuntos">
                                <af:panelGroupLayout id="pgl6" layout="vertical"
                                                     shortDesc="Documento Principal para Descargar"
                                                     inlineStyle="margin-left: 5px; margin-right: 2px;">
                                    <af:panelBox id="pb3" text="Documento Principal para Descargar">
                                        <af:panelFormLayout id="pfl4" rows="1" maxColumns="1">
