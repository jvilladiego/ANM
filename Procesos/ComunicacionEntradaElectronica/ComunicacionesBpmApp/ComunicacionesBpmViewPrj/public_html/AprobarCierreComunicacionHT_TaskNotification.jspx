                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage label="#{bindings.cuenta.hints.label}" id="plam63">
                                        <af:outputText value="#{bindings.cuenta.inputValue}"
                                                       shortDesc="#{bindings.cuenta.hints.tooltip}" id="ot48"/>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage label="#{bindings.idTramite.hints.label}" id="plam55">
                                        <af:outputText value="#{bindings.idTramite.inputValue}"
                                                       shortDesc="#{bindings.idTramite.hints.tooltip}" id="ot5">
                                            <af:convertNumber groupingUsed="false"
                                                              pattern="#{bindings.idTramite.format}"/>
                                        </af:outputText>
                                    </af:panelLabelAndMessage>
                                </af:panelFormLayout>
                            </af:panelGroupLayout>
                            <af:panelGroupLayout layout="vertical" shortDesc="#{resources.CONTENTS}"
                                                 inlineStyle="margin-left: 5px; margin-right: 2px;" id="pgl17">
                                <af:outputText value="Resultado Revision BO" shortDesc="#{bindings.title.hints.tooltip}"
                                               inlineStyle="font-family:Tahoma, Verdana, Helvetica, sans-serif;font-size:11px;font-weight:bold;display:inline;margin:0px;white-space:nowrap;color:#3E403D"
                                               id="ot10"/>
                                <af:panelFormLayout id="pfl12">
                                    <af:panelLabelAndMessage label="#{bindings.resultadoRevision.hints.label}"
                                                             id="plam48">
                                        <af:outputText value="#{bindings.resultadoRevision.inputValue}"
                                                       shortDesc="#{bindings.resultadoRevision.hints.tooltip}"
                                                       id="ot80"/>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage label="#{bindings.comentarioRevision.hints.label}"
                                                             id="plam54">
                                        <af:outputText value="#{bindings.comentarioRevision.inputValue}"
                                                       shortDesc="#{bindings.comentarioRevision.hints.tooltip}"
                                                       id="ot12"/>
                                    </af:panelLabelAndMessage>
                                </af:panelFormLayout>
                            </af:panelGroupLayout>
                        </af:panelGroupLayout>
                    </af:showDetailHeader>
                    <af:spacer height="20" id="s9"/>
                    <af:showDetailHeader size="2" id="histHd" text="#{resources.HISTORY}"
                                         disclosureListener="#{pageFlowScope.aleComponentBean.toggle}" disclosed="true">
                        <f:facet name="info"/>
                        <f:facet name="legend"/>
                        <f:facet name="menuBar"/>
                        <f:facet name="toolbar"/>
                        <f:facet name="context"/>
                        <af:panelGroupLayout layout="vertical" binding="#{pageFlowScope.aleComponentBean.historyPanel}"
                                             id="historyPanel">
                            <wlc:taskHistory initParam="#{pageFlowScope.aleComponentBean.comp}" showTabularView="true"
                                             showGraphicalView="true" id="taskHst"/>
                        </af:panelGroupLayout>
                    </af:showDetailHeader>
                    <af:spacer height="20" id="s21"/>
                    <af:showDetailHeader size="2" id="cmAtt" inlineStyle="margin-top:24px;" disclosed="true"
                                         shortDesc="#{resources.COMMENTS}" text="#{resources.COMMENTS}">
                        <af:switcher facetName="#{actionAvailable.inNotificationClient}" id="s18">
                            <f:facet name="false">
                                <af:table verticalGridVisible="false" horizontalGridVisible="false"
                                          value="#{bindings.userComment2.children}" var="row"
                                          rows="#{bindings.userComment2.rangeSize}"
                                          first="#{bindings.userComment2.rangeStart}"
                                          emptyText="#{bindings.userComment2.viewable ? resources.NO_ROWS_YET : resources.ACCESS_DENIED}"
                                          selectedRowKeys="#{bindings.userComment2.collectionModel.selectedRow}"
                                          selectionListener="#{bindings.userComment2.collectionModel.makeCurrent}"
                                          rowSelection="none" immediate="true" contentDelivery="immediate"
                                          inlineStyle="overflow:auto;border:0px;width:720px" columnStretching="last"
                                          summary="resources.COMMENTS_FOR_WORKLIST_TASK" id="t2">
                                    <af:column width="700px" noWrap="false" separateRows="true" id="c5">
                                        <af:panelGroupLayout layout="horizontal" id="pgl1">
                                            <af:outputText value="#{row.updatedDate}" inlineStyle="font-weight:bold"
                                                           truncateAt="9999" id="ot38"/>
                                            <af:outputText value="#{row.updatedBy.displayName}" truncateAt="9999"
                                                           inlineStyle="margin-left:12px;font-weight:bold" id="ot18"/>
                                        </af:panelGroupLayout>
                                        <af:outputText value="#{row.comment}" truncateAt="9999"
                                                       inlineStyle="margin-left:12px;font-weight:normal" id="ot58"/>
                                    </af:column>
                                </af:table>
                            </f:facet>
                            <f:facet name="true">
                                <af:switcher facetName="#{empty bindings.userComment.children}" id="s23">
                                    <f:facet name="true">
                                        <af:panelGroupLayout layout="horizontal" id="pgl5">
                                            <af:spacer width="20" id="s6"/>
                                            <af:outputText value="#{resources.NO_ROWS_YET}" id="ot67"/>
                                        </af:panelGroupLayout>
                                    </f:facet>
                                    <f:facet name="false">
                                        <af:listView value="#{bindings.userComment.children}" var="row" rows="0"
                                                     id="lv1">
                                            <af:listItem id="li1">
                                                <af:panelGroupLayout layout="horizontal" id="pgl13">
                                                    <af:spacer width="20" id="s25"/>
                                                    <af:outputText value="#{row.updatedDate}"
                                                                   inlineStyle="font-weight:bold" id="ot53">
                                                        <f:convertDateTime type="#{pageFlowScope.dt}"
                                                                           timeZone="#{pageFlowScope.tz}"
                                                                           dateStyle="#{pageFlowScope.df}"
                                                                           timeStyle="#{pageFlowScope.tf}"
                                                                           pattern="#{pageFlowScope.dateTimePattern}"/>
                                                    </af:outputText>
                                                    <af:spacer width="12" id="s3"/>
                                                    <af:outputText value="#{row.updatedBy.displayName}"
                                                                   inlineStyle="font-weight:bold" id="ot28"/>
                                                </af:panelGroupLayout>
                                                <af:spacer width="20" id="s4"/>
                                                <af:outputText value="#{row.comment}" id="ot7"/>
                                                <af:spacer height="10" id="s20"/>
                                            </af:listItem>
                                        </af:listView>
                                    </f:facet>
                                </af:switcher>
                            </f:facet>
                        </af:switcher>
                    </af:showDetailHeader>
                    <af:spacer height="20" id="s15"/>
                    <af:showDetailHeader size="2" text="#{resources.RELATED_LINKS}" disclosed="true"
                                         contentStyle="padding: 5px;" id="sdh2">
                        <af:switcher facetName="#{actionAvailable.inNotificationClient}" id="s8">
                            <f:facet name="true">
                                <af:switcher facetName="#{empty bindings.attachment.children}" id="s24">
                                    <f:facet name="true">
                                        <af:panelGroupLayout layout="horizontal" id="pgl2">
                                            <af:spacer width="20" id="s22"/>
                                            <af:outputText value="#{resources.NO_ROWS_YET}" id="ot50"/>
                                        </af:panelGroupLayout>
                                    </f:facet>
                                    <f:facet name="false">
                                        <af:listView value="#{bindings.attachment.collectionModel}" var="row" rows="0"
                                                     rendered="#{pageFlowScope.ADFHumanTaskBean.isAttachmentReady}"
                                                     id="lv2">
                                            <af:listItem id="li2">
                                                <af:panelGroupLayout layout="horizontal" id="pgl3">
                                                    <af:spacer width="20" id="s14"/>
                                                    <af:outputText value="#{row.updatedDate}" id="ot66">
                                                        <f:convertDateTime type="#{pageFlowScope.dt}"
                                                                           timeZone="#{pageFlowScope.tz}"
                                                                           dateStyle="#{pageFlowScope.df}"
                                                                           timeStyle="#{pageFlowScope.tf}"
                                                                           pattern="#{pageFlowScope.dateTimePattern}"/>
                                                    </af:outputText>
                                                    <af:spacer width="12" id="s5"/>
                                                    <af:switcher facetName="#{!empty row.updatedByDisplayName}"
                                                                 id="s10">
                                                        <f:facet name="true">
                                                            <af:outputText value="#{row.updatedByDisplayName}"
                                                                           id="ot46"/>
                                                        </f:facet>
                                                        <f:facet name="false">
                                                            <af:outputText value="#{row.updatedBy}" id="ot21"/>
                                                        </f:facet>
                                                    </af:switcher>
                                                </af:panelGroupLayout>
                                                <af:panelGroupLayout id="pgl6">
                                                    <af:spacer width="20" id="s17"/>
                                                    <af:switcher facetName="#{row.attachmentScope eq 'BPM'}" id="s7">
                                                        <f:facet name="true">
                                                            <af:switcher facetName="#{row.updatedBy eq pageFlowScope.ADFHumanTaskBean.user}"
                                                                         id="s13">
                                                                <f:facet name="false">
                                                                    <af:link text="#{row.name}"
                                                                             destination="#{pageFlowScope.readAttachmentBean.URL}"
                                                                             shortDesc="#{resources.CANNOT_DEL_ATTACH}"
                                                                             targetFrame="_blank"
                                                                             inlineStyle="font-weight:bold; font-size:11px"
                                                                             id="l3"/>
                                                                </f:facet>
                                                                <f:facet name="true">
                                                                    <af:link text="#{row.name}"
                                                                             destination="#{pageFlowScope.readAttachmentBean.URL}"
                                                                             targetFrame="_blank"
                                                                             inlineStyle="font-weight:bold; font-size:11px"
                                                                             id="l2"/>
                                                                </f:facet>
                                                            </af:switcher>
                                                        </f:facet>
                                                        <f:facet name="false">
                                                            <af:link text="#{row.name}"
                                                                     destination="#{pageFlowScope.readAttachmentBean.URL}"
                                                                     targetFrame="_blank"
                                                                     inlineStyle="font-weight:bold; font-size:11px"
                                                                     id="l1"/>
                                                        </f:facet>
                                                    </af:switcher>
                                                    <af:spacer height="10" id="s1"/>
                                                </af:panelGroupLayout>
                                            </af:listItem>
                                        </af:listView>
                                    </f:facet>
                                </af:switcher>
                            </f:facet>
                        </af:switcher>
                    </af:showDetailHeader>
                </af:panelGroupLayout>
            </af:form>
        </af:document>
    </f:view>
</jsp:root>
