<?xml version='1.0' encoding='UTF-8'?>
<taskDefinition targetNamespace="http://xmlns.oracle.com/ComunicacionesEntFisicaBPM/ComunicacionesEntFisicaPrj/HT_AsignarUsuarioGestionComp" xmlns:xp20="http://www.oracle.com/XSL/Transform/java/oracle.tip.pc.services.functions.Xpath20" xmlns:ora="http://schemas.oracle.com/xpath/extension" xmlns:oraext="http://www.oracle.com/XSL/Transform/java/oracle.tip.pc.services.functions.ExtFunc" xmlns:task="http://xmlns.oracle.com/bpel/workflow/task" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns="http://xmlns.oracle.com/bpel/workflow/taskDefinition" xmlns:bpm="http://xmlns.oracle.com/bpmn20/extensions" xmlns:hwf="http://xmlns.oracle.com/bpel/workflow/xpath" xmlns:xref="http://www.oracle.com/XSL/Transform/java/oracle.tip.xref.xpath.XRefXPathFunctions" xmlns:ns0="http://xmlns.oracle.com/bpel/workflow/common" xmlns:dvm="http://www.oracle.com/XSL/Transform/java/oracle.tip.dvm.LookupValue" xmlns:ids="http://xmlns.oracle.com/bpel/services/IdentityService/xpath" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:evidence="http://xmlns.oracle.com/bpel/workflow/TaskEvidenceService" xmlns:ns1="http://xmlns.oracle.com/bpm/bpmobject/SGDComunicaciones/ComunicacionSalidaBO" xmlns:ns2="http://xmlns.oracle.com/bpm/bpmobject/SGDComunicaciones/RolBO" xmlns:ns3="http://xmlns.oracle.com/bpm/bpmobject/SGDComunicaciones/UsuarioBO" xmlns:socket="http://www.oracle.com/XSL/Transform/java/oracle.tip.adapter.socket.ProtocolTranslator" xmlns:bpws="http://schemas.xmlsoap.org/ws/2003/03/business-process/" xmlns:oraxsl="http://www.oracle.com/XSL/Transform/java" xmlns:xdk="http://schemas.oracle.com/bpel/extension/xpath/function/xdk" xmlns:fn="http://www.w3.org/2005/xpath-functions" xmlns:ns5="http://xmlns.oracle.com/bpm/bpmobject/SGDComunicaciones/AnexosList" xmlns:mhdr="http://www.oracle.com/XSL/Transform/java/oracle.tip.mediator.service.common.functions.MediatorExtnFunction" xmlns:ns4="http://xmlns.oracle.com/bpm/bpmobject/SGDComunicaciones/InteresadoBO" xmlns:ess="http://xmlns.oracle.com/scheduler" xmlns:med="http://schemas.oracle.com/mediator/xpath" xmlns:bpel="http://docs.oasis-open.org/wsbpel/2.0/process/executable" xmlns:ldap="http://schemas.oracle.com/xpath/extension/ldap">
   <name>HT_AsignarUsuarioGestionComp</name>
   <id>${domain_id}_${process_id}_${process_revision}_HT_AsignarUsuarioGestionComp</id>
   <title type="STATIC"><value>Asignar usuario gestión compartida</value></title>
   <priority>3</priority>
   <hideCreator>false</hideCreator>
   <process processId="" processVersion=""/>
   <routingSlip xmlns="http://xmlns.oracle.com/bpel/workflow/routingSlip" routingType="TEMPLATE">
      <globalConfiguration>
         <applicationContext>OracleBPMProcessRolesApp</applicationContext>
         <taskOwner type="STATIC" identityType="application_role">ComunicacionesEntFisicaPrj.ProcessOwner</taskOwner>
         <sharePayloadConfiguration>
            <type>USE_SYSTEM_WIDE_GLOBAL_CONFIGURATION</type>
         </sharePayloadConfiguration>
         <errorOnEmptyAssignee>false</errorOnEmptyAssignee>
         <excludeSaturdayAndSunday>false</excludeSaturdayAndSunday>
      </globalConfiguration>
      <participants isAdhocRoutingSupported="false">
         <stage name="Stage1" disabled="false">
            <participant disabled="false" name="default.DefaultPerformer">
               <resource type="XPATH" identityType="user">/task:task/task:payload/task:usuarioJefeGestionCompDO</resource>
               <dynamicAssignment identityTypeToSelect="user">
                  <assignmentPattern patternName="LEAST_BUSY" isGlobalPattern="false"/>
               </dynamicAssignment>
            </participant>
         </stage>
      </participants>
      <notification includeTaskAttachments="false" actionable="false" secureNotifications="false"
                    oneNotificationPerUserPerAction="false" hideWorklistUrlInEmail="false">
         <action name="ASSIGN" recipient="ASSIGNEES">
            <![CDATA[concat(string('Task '), /task:task/task:title, string(' requires your attention.'))]]>
         </action>
         <action name="COMPLETE" recipient="CREATOR">
            <![CDATA[concat(string('Task '), /task:task/task:title, string(' requires your attention.'))]]>
         </action>
         <action name="ERROR" recipient="OWNER">
            <![CDATA[concat(string('Task '), /task:task/task:title, string(' requires your attention.'))]]>
         </action>
         <groupNotificationConfiguration>SEND_INDIVIDUAL_NOTIFICATION</groupNotificationConfiguration>
         <commentScope>TASK</commentScope>
      </notification>
   </routingSlip>
   <workflowConfiguration features="ucm,RSCUSTOMIZATION" xmlns:ns0="http://xmlns.oracle.com/bpm/bpmobject/SGDComunicaciones/ComunicacionSalidaBO" xmlns:ns1="http://xmlns.oracle.com/bpm/bpmobject/SGDComunicaciones/UsuarioBO" xmlns:ns2="http://xmlns.oracle.com/bpm/bpmobject/SGDComunicaciones/TaxonomiaBO" xmlns="http://xmlns.oracle.com/bpel/workflow/configuration" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:ns3="http://xmlns.oracle.com/bpm/bpmobject/SGDComunicaciones/AnexosList" xmlns:ns4="http://xmlns.oracle.com/bpm/bpmobject/SGDComunicaciones/InteresadoBO">
      <outcomes default="ACCEPT">
         <outcome>ACCEPT</outcome>
      </outcomes>
      <payload externalSchema="false" xmlSchemaDefinition="../Schemas/HT_AsignarUsuarioGestionCompPayload.xsd"
               typedTaskSchemaLocation="../Schemas/HT_AsignarUsuarioGestionCompWorkflowTask.xsd">
         <messageAttribute name="ComunicacionSalidaBO" attributeType="ELEMENT" type="ns0:ComunicacionSalidaBO"
                           updatable="true" external="false"/>
         <messageAttribute name="UsuarioBO" attributeType="ELEMENT" type="ns1:UsuarioBO" updatable="true"
                           external="false"/>
         <messageAttribute name="usuarioJefeGestionCompDO" attributeType="SIMPLE_TYPE" type="xsd:string"
                           updatable="true" external="false"/>
         <messageAttribute name="usuarioGestionCompDO" attributeType="SIMPLE_TYPE" type="xsd:string" updatable="true"
                           external="false"/>
         <messageAttribute name="AnexosList" attributeType="ELEMENT" type="ns3:AnexosList" updatable="true"
                           external="false"/>
         <messageAttribute name="esPqrsBO" attributeType="SIMPLE_TYPE" type="xsd:string" updatable="true"
                           external="false"/>
         <messageAttribute name="tipoPqrsBO" attributeType="SIMPLE_TYPE" type="xsd:string" updatable="true"
                           external="false"/>
         <messageAttribute name="InteresadoBO" attributeType="ELEMENT" type="ns4:InteresadoBO" updatable="true"
                           external="false"/>
         <messageAttribute name="tiempoRespuestaBO" attributeType="SIMPLE_TYPE" type="xsd:integer" updatable="true"
                           external="false"/>
         <messageAttribute name="vencimiento" attributeType="SIMPLE_TYPE" type="xsd:dateTime" updatable="true"
                           external="false"/>
         <messageAttribute name="asunto" attributeType="SIMPLE_TYPE" type="xsd:string" updatable="true"
                           external="false"/>
         <messageAttribute name="radicado" attributeType="SIMPLE_TYPE" type="xsd:string" updatable="true"
                           external="false"/>
         <messageAttribute name="fechaRadicacion" attributeType="SIMPLE_TYPE" type="xsd:dateTime" updatable="true"
                           external="false"/>
      </payload>
      <flexfieldMappings>
         <flexfieldMapping>
            <xpathExpression>/task:task/task:payload/task:asunto</xpathExpression>
            <attributeLabel>
               <labelName>asunto</labelName>
               <flexfield>ProtectedTextAttribute11</flexfield>
               <description>Asunto</description>
            </attributeLabel>
            <description>Asunto</description>
         </flexfieldMapping>
         <flexfieldMapping>
            <xpathExpression>/task:task/task:payload/task:radicado</xpathExpression>
            <attributeLabel>
               <labelName>numeroRadicado</labelName>
               <flexfield>ProtectedTextAttribute12</flexfield>
               <description>Numero radicado</description>
            </attributeLabel>
            <description>Numero radicado</description>
         </flexfieldMapping>
         <flexfieldMapping>
            <xpathExpression>/task:task/task:payload/task:vencimiento</xpathExpression>
            <attributeLabel>
               <labelName>fechaVencimiento</labelName>
               <flexfield>ProtectedDateAttribute1</flexfield>
               <description>Auto-generated for BPM Process</description>
            </attributeLabel>
            <description>Fecha vencimiento</description>
         </flexfieldMapping>
         <flexfieldMapping>
            <xpathExpression>/task:task/task:payload/task:fechaRadicacion</xpathExpression>
            <attributeLabel>
               <labelName>fechaRadicacion</labelName>
               <flexfield>ProtectedDateAttribute2</flexfield>
               <description>Auto-generated for BPM Process</description>
            </attributeLabel>
            <description>Fecha radicacion</description>
         </flexfieldMapping>
      </flexfieldMappings>
      <bpelEventListener>false</bpelEventListener>
      <bpelNoCallbacks>false</bpelNoCallbacks>
      <accessRules>
         <actionRules>
            <systemAction>REASSIGN</systemAction>
            <roles>
               <role privilege="PERMIT">ADMIN</role>
               <role privilege="PERMIT">OWNER</role>
               <role privilege="RESTRICT">APPROVERS</role>
               <role privilege="RESTRICT">CREATOR</role>
               <role privilege="RESTRICT">REVIEWERS</role>
               <role privilege="RESTRICT">ASSIGNEES</role>
            </roles>
         </actionRules>
         <actionRules>
            <systemAction>WITHDRAW</systemAction>
            <roles>
               <role privilege="PERMIT">ADMIN</role>
               <role privilege="PERMIT">OWNER</role>
               <role privilege="RESTRICT">APPROVERS</role>
               <role privilege="RESTRICT">ASSIGNEES</role>
               <role privilege="RESTRICT">REVIEWERS</role>
               <role privilege="RESTRICT">CREATOR</role>
            </roles>
         </actionRules>
      </accessRules>
      <showCompleteGraphicalHistory>true</showCompleteGraphicalHistory>
      <reevalTranslatablesOnUpdate>false</reevalTranslatablesOnUpdate>
      <preActionMandatoryUserSteps/>
      <allowInitiatorEditParticipants>false</allowInitiatorEditParticipants>
      <allowParticipantsEditParticipants>false</allowParticipantsEditParticipants>
      <globalCreationTask>false</globalCreationTask>
      <enableAutoClaim>true</enableAutoClaim>
      <workflowConditions/>
      <taskSequenceTypes>FUTURE</taskSequenceTypes>
      <taskSequenceTypes>AGGREGATE</taskSequenceTypes>
   </workflowConfiguration>
</taskDefinition>
