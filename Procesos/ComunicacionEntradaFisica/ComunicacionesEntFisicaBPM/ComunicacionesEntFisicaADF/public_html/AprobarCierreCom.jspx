<?xml version='1.0' encoding='UTF-8'?>
<jsp:root xmlns:jsp="http://java.sun.com/JSP/Page" version="2.1" xmlns:f="http://java.sun.com/jsf/core"
          xmlns:af="http://xmlns.oracle.com/adf/faces/rich">
    <jsp:directive.page contentType="text/html;charset=UTF-8"/>
    <f:view xmlns:c="http://java.sun.com/jsp/jstl/core" xmlns:trh="http://myfaces.apache.org/trinidad/html"
            xmlns:wf="http://xmlns.oracle.com/bpel/workflow/workflow-taglib.tld"
            xmlns:wlc="http://xmlns.oracle.com/bpel/workflow/worklist">
        <af:document title="AprobarCierreCom.jspx" id="d1">
            <af:messages id="m1"/>
            <af:resource type="javascript" source="/jsLibs/taskDetails.js"/>
            <af:resource type="javascript" source="/jsLibs/commonBPM.js"/>
            <af:form id="f1" usesUpload="true">
                <af:panelGroupLayout layout="vertical" inlineStyle="padding: 5px;" id="pgl1">
                    <af:panelHeader text="#{bindings.title.inputValue}" id="ph1">
                        <f:facet name="info"/>
                        <f:facet name="legend"/>
                        <f:facet name="menuBar"/>
                        <f:facet name="toolbar">
                            <af:toolbar visible="#{actionAvailable.toolbarAvailable}" id="t1">
                                <af:switcher id="customActionButtons"
                                             facetName="#{actionAvailable.isCustomActionButtons}">
                                    <f:facet name="true">
                                        <af:panelGroupLayout layout="horizontal" id="pgl2">
                                            <af:button actionListener="#{invokeActionBean.setOperation}"
                                                       text="#{wf:getResourceValue('APPROVE', 'bindings.customActions')}"
                                                       disabled="#{!bindings.APPROVE.enabled}"
                                                       action="#{invokeActionBean.invokeOperation}"
                                                       partialSubmit="false"
                                                       visible="#{wf:isCustomActionAvailable('APPROVE', 'bindings.customActions')}"
                                                       id="b1">
                                                <f:attribute name="DC_OPERATION_BINDING" value="bindings.APPROVE"/>
                                            </af:button>
                                            <af:button actionListener="#{invokeActionBean.setOperation}"
                                                       text="#{wf:getResourceValue('REJECT', 'bindings.customActions')}"
                                                       disabled="#{!bindings.REJECT.enabled}"
                                                       action="#{invokeActionBean.invokeOperation}"
                                                       partialSubmit="false"
                                                       visible="#{wf:isCustomActionAvailable('REJECT', 'bindings.customActions')}"
                                                       id="b2">
                                                <f:attribute name="DC_OPERATION_BINDING" value="bindings.REJECT"/>
                                            </af:button>
                                        </af:panelGroupLayout>
                                    </f:facet>
                                </af:switcher>
                                <af:button actionListener="#{invokeActionBean.setOperation}" text="#{resources.CLAIM}"
                                           id="Claim" action="#{invokeActionBean.invokeOperation}" partialSubmit="false"
                                           visible="false">
                                    <f:attribute name="DC_OPERATION_BINDING" value="bindings.Claim"/>
                                </af:button>
                                <af:button id="acknowledge" actionListener="#{invokeActionBean.setOperation}"
                                           text="#{resources.ACKNOWLEDGE}" action="#{invokeActionBean.invokeOperation}"
                                           partialSubmit="false" visible="#{actionAvailable.isFyiTask}">
                                    <f:attribute name="DC_OPERATION_BINDING" value="bindings.Acknowledge"/>
                                </af:button>
                                <af:button id="resume" actionListener="#{invokeActionBean.setOperation}"
                                           text="#{resources.RESUME}" action="#{invokeActionBean.invokeOperation}"
                                           partialSubmit="false" visible="#{actionAvailable.resumeAvailable}">
                                    <f:attribute name="DC_OPERATION_BINDING" value="bindings.Resume"/>
                                </af:button>
                                <af:panelGroupLayout layout="horizontal" id="pgl3">
                                    <af:group rendered="#{!((empty actionAvailable.customActions) and (empty actionAvailable.redirectActions) and (empty actionAvailable.otherActions)) || bindings.update.enabled}"
                                              id="g1">
                                        <af:menuBar id="mb1">
                                            <af:menu id="acts" text="#{resources.TASK_ACTIONS}" 
                                                     visible="false">
                                                <af:group id="g2">
                                                    <af:forEach var="childNode1"
                                                                items="#{actionAvailable.customActions}">
                                                        <af:commandMenuItem textAndAccessKey="#{childNode1.displayName}"
                                                                            actionListener="#{invokeActionBean.setAction}"
                                                                            action="#{invokeActionBean.action}"
                                                                            partialSubmit="false" id="cmi2">
                                                            <f:attribute name="ACTION_MENU_ITEM"
                                                                         value="#{childNode1.action}"/>
                                                        </af:commandMenuItem>
                                                    </af:forEach>
                                                </af:group>
                                                <af:group id="g3">
                                                    <af:forEach var="childNode2"
                                                                items="#{actionAvailable.redirectActions}">
                                                        <af:commandMenuItem textAndAccessKey="#{resources[childNode2]}"
                                                                            actionListener="#{invokeActionBean.setAction}"
                                                                            action="#{invokeActionBean.action}"
                                                                            partialSubmit="true" id="cmi1">
                                                            <f:attribute name="ACTION_MENU_ITEM" value="#{childNode2}"/>
                                                        </af:commandMenuItem>
                                                    </af:forEach>
                                                </af:group>
                                                <af:group id="g4">
                                                    <af:forEach var="childNode3"
                                                                items="#{actionAvailable.otherActions}">
                                                        <af:commandMenuItem textAndAccessKey="#{resources[childNode3]}"
                                                                            actionListener="#{invokeActionBean.setAction}"
                                                                            action="#{invokeActionBean.action}"
                                                                            partialSubmit="false" id="cmi4">
                                                            <f:attribute name="ACTION_MENU_ITEM" value="#{childNode3}"/>
                                                        </af:commandMenuItem>
                                                    </af:forEach>
                                                </af:group>
                                                <af:group id="g5">
                                                    <af:commandMenuItem id="save" textAndAccessKey="#{resources.SAVE}"
                                                                        actionListener="#{invokeActionBean.setAction}"
                                                                        action="#{invokeActionBean.action}"
                                                                        partialSubmit="false"
                                                                        rendered="#{actionAvailable.updateAvailable}">
                                                        <f:attribute name="ACTION_MENU_ITEM" value="bindings.update"/>
                                                    </af:commandMenuItem>
                                                </af:group>
                                            </af:menu>
                                        </af:menuBar>
                                    </af:group>
                                </af:panelGroupLayout>
                                <af:spacer width="10" id="s1"/>
                                <af:link shortDesc="#{resources.PREVIOUS_TASK}"
                                         icon="#{ adfFacesContext.rightToLeft ? '/hw_images/nexttraversalarrow_ena.png'  : '/hw_images/previoustraversalarrow_ena.png'}"
                                         action="fetchPreviousTask"
                                         visible="#{pageFlowScope.enableNavigationButton != null}" id="l1"/>
                                <af:spacer width="10" id="s2"/>
                                <af:link shortDesc="#{resources.NEXT_TASK}"
                                         icon="#{ adfFacesContext.rightToLeft ? '/hw_images/previoustraversalarrow_ena.png' : '/hw_images/nexttraversalarrow_ena.png'}"
                                         action="fetchNextTask"
                                         visible="#{pageFlowScope.enableNavigationButton != null}" id="l2"/>
                                <af:spacer width="10" id="s3"/>
                                <af:link shortDesc="#{resources.SHORT_DESC_CLOSE}" icon="/hw_images/close_ena.png"
                                         action="closeTaskFlow"
                                         visible="#{pageFlowScope.enableNavigationButton != null}" id="l3"/>
                            </af:toolbar>
                        </f:facet>
                        <f:facet name="context"/>
                        <af:panelGroupLayout layout="vertical" id="pgl4">
                            <af:showDetailHeader size="2" id="dtHead" text="#{resources.DETAILS}"
                                                 shortDesc="#{resources.TASK_HEADER}" visible="false"
                                                 icon="/hw_images/singleapprover_35x35.png"
                                                 disclosed="#{actionAvailable.discloseHeader}">
                                <f:facet name="context">
                                    <af:link icon="/hw_images/info.png" id="button" clientComponent="true"
                                             rendered="#{!empty bindings.activityId.inputValue}">
                                        <af:showPopupBehavior popupId="helpPopup" align="afterEnd" alignId="button"/>
                                    </af:link>
                                </f:facet>
                                <f:facet name="toolbar"/>
                                <!--trh:tableLayout id="detailTableLayout" width="98%">
                        <trh:rowLayout>
                            <trh:cellFormat width="50%" valign="top"-->
                                <af:panelFormLayout maxColumns="2" rows="4" id="pfl1">
                                    <af:switcher facetName="#{bindings.taskViewContext == 'FYI'}" id="s5">
                                        <f:facet name="false">
                                            <af:panelLabelAndMessage id="assignees" label="#{resources.ASSIGNEES}">
                                                <af:iterator var="assignees" varStatus="varS"
                                                             value="#{bindings.assignees.collectionModel}" id="i1">
                                                    <af:switcher facetName="#{varS.index == 0}" id="s6">
                                                        <f:facet name="false">
                                                            <af:outputText value=", " id="ot1"/>
                                                        </f:facet>
                                                    </af:switcher>
                                                    <af:switcher facetName="#{!empty assignees.displayName}" id="s7">
                                                        <f:facet name="true">
                                                            <af:outputText value="#{assignees.displayName}" id="ot2"/>
                                                        </f:facet>
                                                        <f:facet name="false">
                                                            <af:outputText value="#{assignees.id}" id="ot3"/>
                                                        </f:facet>
                                                    </af:switcher>
                                                </af:iterator>
                                            </af:panelLabelAndMessage>
                                        </f:facet>
                                    </af:switcher>
                                    <af:panelLabelAndMessage id="creator" label="#{resources.CREATOR}">
                                        <af:outputText value="#{bindings.creatorDisplayName.inputValue}" id="ot4"/>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="createdDate" label="#{resources.CREATE_DATE}">
                                        <af:outputText value="#{bindings.createdDate.inputValue}" noWrap="true"
                                                       id="ot5">
                                            <f:convertDateTime type="#{pageFlowScope.dt}" timeZone="#{pageFlowScope.tz}"
                                                               dateStyle="#{pageFlowScope.df}"
                                                               timeStyle="#{pageFlowScope.tf}"
                                                               pattern="#{pageFlowScope.dateTimePattern}"/>
                                        </af:outputText>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="updatedDate" label="#{resources.UPDATE_DATE}">
                                        <af:outputText value="#{bindings.updatedDate.inputValue}" noWrap="true"
                                                       id="ot6">
                                            <f:convertDateTime type="#{pageFlowScope.dt}" timeZone="#{pageFlowScope.tz}"
                                                               dateStyle="#{pageFlowScope.df}"
                                                               timeStyle="#{pageFlowScope.tf}"
                                                               pattern="#{pageFlowScope.dateTimePattern}"/>
                                        </af:outputText>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="expirationDate" label="#{resources.EXPIRATION_DATE}">
                                        <af:outputText value="#{bindings.expirationDate.inputValue}" id="ot7">
                                            <f:convertDateTime type="#{pageFlowScope.dt}" timeZone="#{pageFlowScope.tz}"
                                                               dateStyle="#{pageFlowScope.df}"
                                                               timeStyle="#{pageFlowScope.tf}"
                                                               pattern="#{pageFlowScope.dateTimePattern}"/>
                                        </af:outputText>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="acquiredBy" label="#{resources.ACQUIRED_BY}">
                                        <af:switcher facetName="#{!empty bindings.acquiredByDisplayName.inputValue}"
                                                     id="s8">
                                            <f:facet name="true">
                                                <af:outputText value="#{bindings.acquiredByDisplayName.inputValue}"
                                                               id="ot8"/>
                                            </f:facet>
                                            <f:facet name="false">
                                                <af:outputText value="#{bindings.acquiredBy.inputValue}" id="ot9"/>
                                            </f:facet>
                                        </af:switcher>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="dueDate" label="#{resources.DUE_DATE}"
                                                             rendered="#{!empty bindings.dueDate.inputValue}">
                                        <af:outputText value="#{bindings.dueDate.inputValue}" noWrap="true" id="ot10">
                                            <f:convertDateTime type="#{pageFlowScope.dt}" timeZone="#{pageFlowScope.tz}"
                                                               dateStyle="#{pageFlowScope.df}"
                                                               timeStyle="#{pageFlowScope.tf}"
                                                               pattern="#{pageFlowScope.dateTimePattern}"/>
                                        </af:outputText>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="outcome" label="#{resources.OUTCOME}"
                                                             rendered="#{!empty bindings.actionDisplayName.inputValue}">
                                        <af:outputText value="#{bindings.actionDisplayName.inputValue}" id="ot11"/>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="taskNumber" label="#{resources.TASK_NUMBER}">
                                        <af:outputText value="#{bindings.taskNumber.inputValue}" id="ot12"/>
                                    </af:panelLabelAndMessage>
                                    <af:inputText id="priority" value="#{bindings.priority.inputValue}"
                                                  label="#{resources.PRIORITY}"
                                                  required="#{bindings.priority.mandatory}" columns="3"
                                                  validator="#{actionAvailable.validatePriorityValue}"/>
                                    <af:panelLabelAndMessage id="state" label="#{resources.STATE}">
                                        <af:outputText value="#{resources[bindings.state.inputValue]}" id="ot13"/>
                                    </af:panelLabelAndMessage>
                                </af:panelFormLayout>
                                <!--/trh:cellFormat>
                            <trh:cellFormat>
                                <af:spacer width="15" height="15"/>
                            </trh:cellFormat>
                            <trh:cellFormat width="50%" valign="top">
                                <af:panelFormLayout>
                                    <f:facet name="footer"/>
                                </af:panelFormLayout>
                            </trh:cellFormat>
                        </trh:rowLayout>
                    </trh:tableLayout-->
                            </af:showDetailHeader>
                            
                            <af:panelBox text="General" id="pb7">
                                <f:facet name="toolbar"/>
                                <af:panelGroupLayout id="pgl23" layout="horizontal" valign="top">
                                    <af:panelFormLayout id="pfl2" visible="#{bindings.nroRadicado.inputValue != null}">
                                        <af:inputText label="No. radicado" value="#{bindings.nroRadicado.inputValue}"
                                                      id="it50" readOnly="true" />
                                        <af:inputText label="Tiempo respuesta"  visible="#{bindings.tiempoRespuestaBO.inputValue ne 0}"
                                                    value="#{bindings.tiempoRespuestaBO.inputValue} (Días Hábiles)" 
                                                      id="it40" readOnly="true" />
                                        <af:inputText label="No. radicado relacionado" value="#{bindings.nroRadicadoRelacionado.inputValue}"
                                                      id="it30" readOnly="true" visible="false"/>
                                    </af:panelFormLayout>
                                            <af:panelFormLayout id="pfl20" >
                                                <af:inputText label="Fecha radicación" value="#{bindings.fechaRadicacion.inputValue}"
                                                              id="it1" readOnly="true">
                                                    <af:convertDateTime pattern="dd-MMM-yyyy"/>
                                                </af:inputText>
                                                <af:inputText label="Fecha vencimiento" value="#{bindings.vencimiento.inputValue}"
                                                              id="it16" readOnly="true" visible="#{bindings.tiempoRespuestaBO.inputValue ne 0}">
                                                    <af:convertDateTime pattern="dd-MMM-yyyy"/>
                                                </af:inputText>
                                        <!--af:inputText value="#{bindings.vencimiento.inputValue}"
                                                      label="#{bindings.vencimiento.hints.label}"
                                                      required="#{bindings.vencimiento.hints.mandatory}"
                                                      columns="#{bindings.vencimiento.hints.displayWidth}"
                                                      maximumLength="#{bindings.vencimiento.hints.precision}"
                                                      shortDesc="#{bindings.vencimiento.hints.tooltip}" id="it17">
                                            <f:validator binding="#{bindings.vencimiento.validator}"/>
                                            <af:convertDateTime pattern="#{bindings.vencimiento.format}"/>
                                        </af:inputText-->
                                    </af:panelFormLayout>
                                            <af:panelFormLayout id="pfl4" >
                                                 
                                                <af:inputText value="#{bindings.creatorDisplayName.inputValue}" id="it8"
                                                        readOnly="true" label="Creador"  />
                                                <af:inputText value="#{bindings.updatedDate.inputValue}" 
                                                               id="it10" readOnly="true" label="Actualizado" >
                                                    <f:convertDateTime type="#{pageFlowScope.dt}" timeZone="#{pageFlowScope.tz}"
                                                                       dateStyle="#{pageFlowScope.df}"
                                                                       timeStyle="#{pageFlowScope.tf}"
                                                                       pattern="#{pageFlowScope.dateTimePattern}"/>
                                                </af:inputText>
                                                <af:inputText label="Dependencia" value="#{operacionBean.anmUnidad.nombreUnidadadministrativa}"
                                                                id="ot15" visible="false"/>
                                            </af:panelFormLayout>
                                            
                                        </af:panelGroupLayout>
                                    </af:panelBox>
                            
                             <af:panelBox text="Remitente" id="pb6">
                                <af:panelFormLayout id="pfl3">
                                    <af:inputText value="#{bindings.idInteresado.inputValue}"
                                                  label="#{bindings.idInteresado.hints.label}"
                                                  required="#{bindings.idInteresado.hints.mandatory}" readOnly="true"
                                                  columns="#{bindings.idInteresado.hints.displayWidth}"
                                                  maximumLength="#{bindings.idInteresado.hints.precision}"
                                                  shortDesc="#{bindings.idInteresado.hints.tooltip}" id="it6"
                                                  visible="false">
                                        <f:validator binding="#{bindings.idInteresado.validator}"/>
                                        <af:convertNumber groupingUsed="false"
                                                          pattern="#{bindings.idInteresado.format}"/>
                                    </af:inputText>
                                    <af:inputText value="#{bindings.tipoIdentificacion1.inputValue}"
                                                  label="#{bindings.tipoIdentificacion1.hints.label}"
                                                  required="#{bindings.tipoIdentificacion1.hints.mandatory}"
                                                  readOnly="true"
                                                  columns="#{bindings.tipoIdentificacion1.hints.displayWidth}"
                                                  maximumLength="#{bindings.tipoIdentificacion1.hints.precision}"
                                                  shortDesc="#{bindings.tipoIdentificacion1.hints.tooltip}" id="it24">
                                        <f:validator binding="#{bindings.tipoIdentificacion1.validator}"/>
                                    </af:inputText>
                                    <af:inputText value="#{bindings.numeroIdentificacion.inputValue}"
                                                  label="#{bindings.numeroIdentificacion.hints.label}"
                                                  required="#{bindings.numeroIdentificacion.hints.mandatory}"
                                                  readOnly="true"
                                                  columns="#{bindings.numeroIdentificacion.hints.displayWidth}"
                                                  maximumLength="#{bindings.numeroIdentificacion.hints.precision}"
                                                  shortDesc="#{bindings.numeroIdentificacion.hints.tooltip}" id="it23">
                                        <f:validator binding="#{bindings.numeroIdentificacion.validator}"/>
                                    </af:inputText>
                                    <af:inputText value="#{bindings.primerNombre.inputValue} #{bindings.segundoNombre.inputValue}"
                                                  label="Nombre(s)"
                                                  required="#{bindings.primerNombre.hints.mandatory}" readOnly="true"
                                                  columns="#{bindings.primerNombre.hints.displayWidth}"
                                                  maximumLength="#{bindings.primerNombre.hints.precision}"
                                                  shortDesc="#{bindings.primerNombre.hints.tooltip}" id="it9">
                                        <f:validator binding="#{bindings.primerNombre.validator}"/>
                                    </af:inputText>
                                    <!--af:inputText value="#{bindings.segundoNombre.inputValue}"
                                                  label="#{bindings.segundoNombre.hints.label}"
                                                  required="#{bindings.segundoNombre.hints.mandatory}" readOnly="true"
                                                  columns="#{bindings.segundoNombre.hints.displayWidth}"
                                                  maximumLength="#{bindings.segundoNombre.hints.precision}"
                                                  shortDesc="#{bindings.segundoNombre.hints.tooltip}" id="it7">
                                        <f:validator binding="#{bindings.segundoNombre.validator}"/>
                                    </af:inputText-->
                                    <af:inputText value="#{bindings.primerApellido.inputValue} #{bindings.segundoApellido.inputValue}"
                                                  label="Apellidos(s)"
                                                  required="#{bindings.primerApellido.hints.mandatory}" readOnly="true"
                                                  columns="#{bindings.primerApellido.hints.displayWidth}"
                                                  maximumLength="#{bindings.primerApellido.hints.precision}"
                                                  shortDesc="#{bindings.primerApellido.hints.tooltip}" id="it11">
                                        <f:validator binding="#{bindings.primerApellido.validator}"/>
                                    </af:inputText>
                                    <!--af:inputText value="#{bindings.segundoApellido.inputValue}"
                                                  label="#{bindings.segundoApellido.hints.label}"
                                                  required="#{bindings.segundoApellido.hints.mandatory}" readOnly="true"
                                                  columns="#{bindings.segundoApellido.hints.displayWidth}"
                                                  maximumLength="#{bindings.segundoApellido.hints.precision}"
                                                  shortDesc="#{bindings.segundoApellido.hints.tooltip}" id="it12">
                                        <f:validator binding="#{bindings.segundoApellido.validator}"/>
                                    </af:inputText-->
                                    <af:inputText value="#{bindings.email2.inputValue}"
                                                  label="#{bindings.email2.hints.label}"
                                                  required="#{bindings.email2.hints.mandatory}" readOnly="true"
                                                  columns="#{bindings.email2.hints.displayWidth}"
                                                  maximumLength="#{bindings.email2.hints.precision}"
                                                  shortDesc="#{bindings.email2.hints.tooltip}" id="it13">
                                        <f:validator binding="#{bindings.email2.validator}"/>
                                    </af:inputText>
                                    <af:inputText value="#{bindings.telefono1.inputValue}"
                                                  label="#{bindings.telefono1.hints.label}"
                                                  required="#{bindings.telefono1.hints.mandatory}" readOnly="true"
                                                  columns="#{bindings.telefono1.hints.displayWidth}"
                                                  maximumLength="#{bindings.telefono1.hints.precision}"
                                                  shortDesc="#{bindings.telefono1.hints.tooltip}" id="it27">
                                        <f:validator binding="#{bindings.telefono1.validator}"/>
                                    </af:inputText>
                                    <af:inputText value="#{bindings.celular.inputValue}"
                                                  label="#{bindings.celular.hints.label}"
                                                  required="#{bindings.celular.hints.mandatory}" readOnly="true"
                                                  columns="#{bindings.celular.hints.displayWidth}"
                                                  maximumLength="#{bindings.celular.hints.precision}"
                                                  shortDesc="#{bindings.celular.hints.tooltip}" id="it20">
                                        <f:validator binding="#{bindings.celular.validator}"/>
                                    </af:inputText>
                                    <af:inputText value="#{bindings.direccion.inputValue}"
                                                  label="#{bindings.direccion.hints.label}"
                                                  required="#{bindings.direccion.hints.mandatory}" readOnly="true"
                                                  columns="#{bindings.direccion.hints.displayWidth}"
                                                  maximumLength="#{bindings.direccion.hints.precision}"
                                                  shortDesc="#{bindings.direccion.hints.tooltip}" id="it21">
                                        <f:validator binding="#{bindings.direccion.validator}"/>
                                    </af:inputText>
                                     <af:selectOneChoice value="#{bindings.idPais.inputValue}" 
                                                      label="País" id="socPais" readOnly="true" contentStyle="margin-top:8px;">
                                            <f:selectItems value="#{operacionBean.lstPais2}" id="si9"/>
                                        </af:selectOneChoice>
                                         <af:selectOneChoice value="#{bindings.idDepartamento.inputValue}"
                                                visible="#{bindings.idPais.inputValue eq 52}" readOnly="true"
                                                      label="Departamento"  id="socDpto" contentStyle="margin-top:8px;">
                                            <f:selectItems value="#{operacionBean.lstDepartamento2}" id="si15"/>
                                        </af:selectOneChoice>
                                            <af:inputText label="Ciudad/Municipio" id="it38" readOnly="true"
                                                    visible="#{bindings.idPais.inputValue eq 52}"
                                                    value="#{bindings.ciudad.inputValue}"/>
                                    <!--af:inputText value="#{bindings.idPais.inputValue}"
                                                  label="País"
                                                  required="#{bindings.idPais.hints.mandatory}" readOnly="true"
                                                  columns="#{bindings.idPais.hints.displayWidth}"
                                                  maximumLength="#{bindings.idPais.hints.precision}"
                                                  shortDesc="#{bindings.idPais.hints.tooltip}" id="it25">
                                        <f:validator binding="#{bindings.idPais.validator}"/>
                                        <af:convertNumber groupingUsed="false" pattern="#{bindings.idPais.format}"/>
