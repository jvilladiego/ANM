                                                  required="#{bindings.idEtnia.hints.mandatory}" readOnly="true"
                                                  columns="#{bindings.idEtnia.hints.displayWidth}"
                                                  maximumLength="#{bindings.idEtnia.hints.precision}"
                                                  shortDesc="#{bindings.idEtnia.hints.tooltip}" id="it14"
                                                  visible="false">
                                        <f:validator binding="#{bindings.idEtnia.validator}"/>
                                        <af:convertNumber groupingUsed="false" pattern="#{bindings.idEtnia.format}"/>
                                    </af:inputText>
                                    <af:inputText value="#{bindings.idDepartamento.inputValue}"
                                                  label="Departamento"
                                                  required="#{bindings.idDepartamento.hints.mandatory}" readOnly="true"
                                                  columns="#{bindings.idDepartamento.hints.displayWidth}"
                                                  maximumLength="#{bindings.idDepartamento.hints.precision}"
                                                  shortDesc="#{bindings.idDepartamento.hints.tooltip}" id="it15">
