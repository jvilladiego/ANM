                                                      value="#{bindings.asunto.inputValue}"/>
                                        <af:panelGroupLayout layout="horizontal" id="pgl24" valign="top">
                                            <af:panelFormLayout id="pfl4">
                                                <af:selectBooleanCheckbox value="#{bindings.esTituloMinero.inputValue eq 'true'}"
                                                                          label="&#191;Es expediente minero?"
                                                                          shortDesc="#{bindings.esTituloMinero.hints.tooltip}"
                                                                          id="sbcPLaca" readOnly="true"/>
                                                <af:inputText label="Nro.placa" id="it43" readOnly="true"
                                                              value="#{bindings.placa.inputValue}"/>
                                                <af:inputText label="Referencia" id="it41" readOnly="true"
                                                              value="#{bindings.referencia.inputValue}"/>
                                            
                                        </af:panelFormLayout>
                                            <af:panelFormLayout id="pfl5">
