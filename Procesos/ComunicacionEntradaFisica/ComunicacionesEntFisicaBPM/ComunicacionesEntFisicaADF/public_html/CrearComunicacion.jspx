                                                  maximumLength="#{bindings.idCuenta.hints.precision}"
                                                  shortDesc="#{bindings.idCuenta.hints.tooltip}" id="it11">
                                        <f:validator binding="#{bindings.idCuenta.validator}"/>
                                    </af:inputText>
                                    <af:inputText value="#{bindings.cuenta.inputValue}"
                                                  label="#{bindings.cuenta.hints.label}"
                                                  required="#{bindings.cuenta.hints.mandatory}"
                                                  columns="#{bindings.cuenta.hints.displayWidth}"
                                                  maximumLength="#{bindings.cuenta.hints.precision}"
                                                  shortDesc="#{bindings.cuenta.hints.tooltip}" id="it19">
                                        <f:validator binding="#{bindings.cuenta.validator}"/>
                                    </af:inputText>
                                    <af:inputText value="#{bindings.idTramite.inputValue}"
                                                  label="#{bindings.idTramite.hints.label}"
                                                  required="#{bindings.idTramite.hints.mandatory}"
                                                  columns="#{bindings.idTramite.hints.displayWidth}"
                                                  maximumLength="#{bindings.idTramite.hints.precision}"
                                                  shortDesc="#{bindings.idTramite.hints.tooltip}" id="it20">
                                        <f:validator binding="#{bindings.idTramite.validator}"/>
