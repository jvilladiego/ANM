                                </af:panelFormLayout-->
                                <af:spacer width="10" id="s1"/>
                                <af:link shortDesc="#{resources.PREVIOUS_TASK}"
                                         icon="#{ adfFacesContext.rightToLeft ? '/hw_images/nexttraversalarrow_ena.png'  : '/hw_images/previoustraversalarrow_ena.png'}"
                                         action="fetchPreviousTask"
                                         visible="#{pageFlowScope.enableNavigationButton != null}" id="l1"/>
                                <af:spacer width="10" id="s2"/>
                                <af:link shortDesc="#{resources.NEXT_TASK}"
                                         icon="#{ adfFacesContext.rightToLeft ? '/hw_images/previoustraversalarrow_ena.png' : '/hw_images/nexttraversalarrow_ena.png'}"
                                         action="fetchNextTask"
                                         visible="#{pageFlowScope.enableNavigationButton != null}" id="l2"/>
                                <af:spacer width="10" id="s3"/>
                                <af:link shortDesc="#{resources.SHORT_DESC_CLOSE}" icon="/hw_images/close_ena.png"
                                         action="closeTaskFlow"
                                         visible="#{pageFlowScope.enableNavigationButton != null}" id="l3"/>
                            </af:toolbar>
                        </f:facet>
                        <f:facet name="context"/>
                        <af:panelGroupLayout layout="vertical" id="pgl4">
                            <f:facet name="separator">
                                <af:spacer width="15" height="15" id="s4"/>
                            </f:facet>
                            <af:showDetailHeader size="2" id="dtHead" text="#{resources.DETAILS}"
                                                 shortDesc="#{resources.TASK_HEADER}"
                                                 icon="/hw_images/singleapprover_35x35.png"
                                                 disclosed="#{actionAvailable.discloseHeader}">
                                <f:facet name="context">
                                    <af:link icon="/hw_images/info.png" id="button" clientComponent="true"
                                             rendered="#{!empty bindings.activityId.inputValue}">
                                        <af:showPopupBehavior popupId="helpPopup" align="afterEnd" alignId="button"/>
                                    </af:link>
                                </f:facet>
                                <f:facet name="toolbar"/>
                                <!--trh:tableLayout id="detailTableLayout" width="98%">
                        <trh:rowLayout>
                            <trh:cellFormat width="50%" valign="top"-->
                                <af:panelFormLayout maxColumns="2" rows="4" id="pfl1">
                                    <af:switcher facetName="#{bindings.taskViewContext == 'FYI'}" id="s5">
                                        <f:facet name="false">
                                            <af:panelLabelAndMessage id="assignees" label="#{resources.ASSIGNEES}">
                                                <af:iterator var="assignees" varStatus="varS"
                                                             value="#{bindings.assignees.collectionModel}" id="i1">
                                                    <af:switcher facetName="#{varS.index == 0}" id="s6">
                                                        <f:facet name="false">
                                                            <af:outputText value=", " id="ot1"/>
                                                        </f:facet>
                                                    </af:switcher>
                                                    <af:switcher facetName="#{!empty assignees.displayName}" id="s7">
                                                        <f:facet name="true">
                                                            <af:outputText value="#{assignees.displayName}" id="ot2"/>
                                                        </f:facet>
                                                        <f:facet name="false">
                                                            <af:outputText value="#{assignees.id}" id="ot3"/>
                                                        </f:facet>
                                                    </af:switcher>
                                                </af:iterator>
                                            </af:panelLabelAndMessage>
                                        </f:facet>
                                    </af:switcher>
                                    <af:panelLabelAndMessage id="creator" label="#{resources.CREATOR}">
                                        <af:outputText value="#{bindings.creatorDisplayName.inputValue}" id="ot4"/>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="createdDate" label="#{resources.CREATE_DATE}">
                                        <af:outputText value="#{bindings.createdDate.inputValue}" noWrap="true"
                                                       id="ot5">
                                            <f:convertDateTime type="#{pageFlowScope.dt}" timeZone="#{pageFlowScope.tz}"
                                                               dateStyle="#{pageFlowScope.df}"
                                                               timeStyle="#{pageFlowScope.tf}"
                                                               pattern="#{pageFlowScope.dateTimePattern}"/>
                                        </af:outputText>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="updatedDate" label="#{resources.UPDATE_DATE}">
                                        <af:outputText value="#{bindings.updatedDate.inputValue}" noWrap="true"
                                                       id="ot6">
                                            <f:convertDateTime type="#{pageFlowScope.dt}" timeZone="#{pageFlowScope.tz}"
                                                               dateStyle="#{pageFlowScope.df}"
                                                               timeStyle="#{pageFlowScope.tf}"
                                                               pattern="#{pageFlowScope.dateTimePattern}"/>
                                        </af:outputText>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="expirationDate" label="#{resources.EXPIRATION_DATE}">
                                        <af:outputText value="#{bindings.expirationDate.inputValue}" id="ot7">
                                            <f:convertDateTime type="#{pageFlowScope.dt}" timeZone="#{pageFlowScope.tz}"
                                                               dateStyle="#{pageFlowScope.df}"
                                                               timeStyle="#{pageFlowScope.tf}"
                                                               pattern="#{pageFlowScope.dateTimePattern}"/>
                                        </af:outputText>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="acquiredBy" label="#{resources.ACQUIRED_BY}">
                                        <af:switcher facetName="#{!empty bindings.acquiredByDisplayName.inputValue}"
                                                     id="s8">
                                            <f:facet name="true">
                                                <af:outputText value="#{bindings.acquiredByDisplayName.inputValue}"
                                                               id="ot8"/>
                                            </f:facet>
                                            <f:facet name="false">
                                                <af:outputText value="#{bindings.acquiredBy.inputValue}" id="ot9"/>
                                            </f:facet>
                                        </af:switcher>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="dueDate" label="#{resources.DUE_DATE}"
                                                             rendered="#{!empty bindings.dueDate.inputValue}">
                                        <af:outputText value="#{bindings.dueDate.inputValue}" noWrap="true" id="ot10">
                                            <f:convertDateTime type="#{pageFlowScope.dt}" timeZone="#{pageFlowScope.tz}"
                                                               dateStyle="#{pageFlowScope.df}"
                                                               timeStyle="#{pageFlowScope.tf}"
                                                               pattern="#{pageFlowScope.dateTimePattern}"/>
                                        </af:outputText>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="outcome" label="#{resources.OUTCOME}"
                                                             rendered="#{!empty bindings.actionDisplayName.inputValue}">
                                        <af:outputText value="#{bindings.actionDisplayName.inputValue}" id="ot11"/>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="taskNumber" label="#{resources.TASK_NUMBER}">
                                        <af:outputText value="#{bindings.taskNumber.inputValue}" id="ot12"/>
                                    </af:panelLabelAndMessage>
                                    <af:inputText id="priority" value="#{bindings.priority.inputValue}"
                                                  label="#{resources.PRIORITY}"
                                                  required="#{bindings.priority.mandatory}" columns="3"
                                                  validator="#{actionAvailable.validatePriorityValue}"/>
                                    <af:panelLabelAndMessage id="state" label="#{resources.STATE}">
                                        <af:outputText value="#{resources[bindings.state.inputValue]}" id="ot13"/>
                                    </af:panelLabelAndMessage>
                                </af:panelFormLayout>
                            </af:showDetailHeader>
                            <af:showDetailHeader size="2" id="apCntHd" text="#{resources.CONTENTS}"
                                                 disclosed="#{actionAvailable.discloseContents}">
                                <af:panelBox text="General" id="pb4">
                                    <af:panelGroupLayout id="pgl23" layout="horizontal">
                                        <af:inputText label="Fecha" value="#{operacionBean.fechaActual}" id="aot1"
                                                      readOnly="true" binding="#{operacionBean.itFecha}">
                                            <af:convertDateTime pattern="dd-MMM-yyyy hh:mm a"/>
                                        </af:inputText>
                                        <af:spacer width="20" height="10" id="s12"/>
                                        <af:inputText label="Funcionario"
                                                      value="#{operacionBean.sgdUsuario.nombreUsuario}" id="ot14"
                                                      readOnly="true"/>
                                        <af:spacer width="20" height="10" id="s13"/>
                                        <af:inputText label="Dependencia"
                                                      value="#{operacionBean.anmUnidad.nombreUnidadadministrativa}"
                                                      id="ot15" readOnly="true"/>
                                        <af:spacer width="20" height="10" id="s14"/>
                                        <af:outputText binding="#{operacionBean.itNoRadicado}"
                                                       visible="#{not empty bindings.nroRadicado.inputValue}"
                                                       value="No. Radicado #{bindings.nroRadicado.inputValue}" id="it2"
                                                       inlineStyle="font-size:16px;font-weight: bold;"/>
                                    </af:panelGroupLayout>
                                </af:panelBox>
                                <af:panelBox text="Asociaciones" id="pb5">
                                    <af:panelGroupLayout id="pgl6" layout="horizontal" valign="top">
                                        <af:panelGroupLayout id="pg_expminero" halign="left">
                                            <af:selectBooleanCheckbox autoSubmit="true" label="&#191;Expediente Minero?"
                                                                      id="sbcExp"
                                                                      value="#{bindings.esTituloMinero.inputValue}"
                                                                      valueChangeListener="#{operacionBean.cambiarExpMinero}"/>
                                            <af:inputText label=" " id="it26" value="#{bindings.placa.inputValue}"
                                                          simple="false"
                                                          required="#{bindings.esTituloMinero.inputValue eq true}"
                                                          autoSubmit="true" placeholder="Placa" partialTriggers="sbcExp"
                                                          binding="#{operacionBean.itPlaca}"
                                                          visible="#{bindings.esTituloMinero.inputValue}"
                                                          valueChangeListener="#{operacionBean.cambiarPlaca}">
                                                          <f:validateLength maximum="100"/>
                                            </af:inputText>
                                        </af:panelGroupLayout>
                                        <af:spacer width="50" height="10" id="s17"/>
                                        <af:panelGroupLayout id="pg_pqrs" halign="left">
                                            <af:selectBooleanCheckbox valueChangeListener="#{operacionBean.cambiarEsPqrs}"
                                                                      text=" " label="&#191;PQRS?" autoSubmit="true"
                                                                      shortDesc="#{bindings.esPqrsBO.hints.tooltip}"
                                                                      value="#{bindings.esPqrsBO.inputValue}"
                                                                      id="socEsPqr"/>
                                            <af:selectOneChoice label="Tipo PQRS" id="socTipoPqrs"
                                                                partialTriggers="socEsPqr" autoSubmit="true"
                                                                visible="#{bindings.esPqrsBO.inputValue}"
                                                                required="#{bindings.esPqrsBO.inputValue eq true}"
                                                                value="#{bindings.tipoPqrsBO.inputValue}"
                                                                valueChangeListener="#{operacionBean.cambiarTipoPqrs}">
                                                <f:selectItems value="#{operacionBean.lstTipoSolicitud}" id="si10"/>
                                            </af:selectOneChoice>
                                            <af:inputText value="#{bindings.nombreTipoPQRS.inputValue}"
                                                          label="#{bindings.nombreTipoPQRS.hints.label}"
                                                          visible="false"
                                                          required="#{bindings.nombreTipoPQRS.hints.mandatory}"
                                                          columns="#{bindings.nombreTipoPQRS.hints.displayWidth}"
                                                          maximumLength="#{bindings.nombreTipoPQRS.hints.precision}"
                                                          shortDesc="#{bindings.nombreTipoPQRS.hints.tooltip}" id="it4">
                                                <f:validator binding="#{bindings.nombreTipoPQRS.validator}"/>
                                            </af:inputText>
                                            <!--<af:inputText value="#{bindings.requiereRespuestaDO.inputValue}"
                                                          label="#{bindings.requiereRespuestaDO.hints.label}"
                                                          required="#{bindings.requiereRespuestaDO.hints.mandatory}"
                                                          columns="#{bindings.requiereRespuestaDO.hints.displayWidth}"
                                                          maximumLength="#{bindings.requiereRespuestaDO.hints.precision}"
                                                          shortDesc="#{bindings.requiereRespuestaDO.hints.tooltip}"
                                                          id="it4">
                                                <f:validator binding="#{bindings.requiereRespuestaDO.validator}"/>
                                            </af:inputText>-->
                                        </af:panelGroupLayout>
                                        <af:spacer width="50" height="10" id="s16"/>
                                        <af:panelGroupLayout id="pg_ref" halign="left">
                                            <af:selectBooleanCheckbox id="socRef" label="&#191;Referencia adicional?"
                                                                      value="#{bindings.tieneReferencia.inputValue}"
                                                                      valueChangeListener="#{operacionBean.cambiarTieneReferencia}"
                                                                      autoSubmit="true"/>
                                            <af:inputText id="it24" label=" " value="#{bindings.referencia.inputValue}"
                                                          autoSubmit="true" simple="false"
                                                          visible="#{bindings.tieneReferencia.inputValue}"
                                                          required="#{bindings.tieneReferencia.inputValue eq true}"
                                                          placeholder="Referencia" partialTriggers="socRef" maximumLength="200">
                                                <f:validateLength maximum="200"/>
                                            </af:inputText>
                                        </af:panelGroupLayout>
                                    </af:panelGroupLayout>
                                </af:panelBox>
                                <af:panelBox text="Informaci&#243;n remitente" id="pb2">
                                    <af:panelFormLayout id="pfl8">
                                        <af:selectOneChoice label="#{bindings.tipoSolicitante.hints.label}"
                                                            required="true"
                                                            value="#{bindings.tipoSolicitante.inputValue}" id="soc244">
                                            <f:selectItems value="#{operacionBean.tiposSolicitantes}" id="si888"/>
                                        </af:selectOneChoice>
                                        <af:selectOneChoice label="#{bindings.tipoIdentificacion.hints.label}"
                                                            required="true"
                                                            value="#{bindings.tipoIdentificacion.inputValue}" id="soc4">
                                            <f:selectItems value="#{operacionBean.lstTiposIdentificacion}" id="si8"/>
                                        </af:selectOneChoice>
                                        <af:inputText value="#{bindings.numeroIdentificacion.inputValue}"
                                                      label="#{bindings.numeroIdentificacion.hints.label}"
                                                      required="true"
                                                      columns="#{bindings.numeroIdentificacion.hints.displayWidth}"
                                                      maximumLength="20"
                                                      shortDesc="#{bindings.numeroIdentificacion.hints.tooltip}"
                                                      id="it30">
                                            <f:validator binding="#{bindings.numeroIdentificacion.validator}"/>
                                            <f:validateLength maximum="20"/>
                                        </af:inputText>
                                        <af:inputText value="#{bindings.primerNombre.inputValue}" required="true"
                                                      label="Primer Nombre  / Raz&#243;n Social"
                                                      columns="#{bindings.primerNombre.hints.displayWidth}"
                                                      maximumLength="100"
                                                      shortDesc="#{bindings.primerNombre.hints.tooltip}" id="it13">
                                            <f:validator binding="#{bindings.primerNombre.validator}"/>
                                            <f:validateLength maximum="100"/>
                                        </af:inputText>
                                        <af:inputText value="#{bindings.segundoNombre.inputValue}"
                                                      label="#{bindings.segundoNombre.hints.label}"
                                                      required="#{bindings.segundoNombre.hints.mandatory}"
                                                      columns="#{bindings.segundoNombre.hints.displayWidth}"
                                                      maximumLength="100"
                                                      shortDesc="#{bindings.segundoNombre.hints.tooltip}" id="it12">
                                            <f:validator binding="#{bindings.segundoNombre.validator}"/>
                                            <f:validateLength maximum="100"/>
                                        </af:inputText>
                                        <af:inputText value="#{bindings.primerApellido.inputValue}"
                                                      label="#{bindings.primerApellido.hints.label}"
                                                      required="#{bindings.primerApellido.hints.mandatory}"
                                                      columns="#{bindings.primerApellido.hints.displayWidth}"
                                                      maximumLength="100"
                                                      shortDesc="#{bindings.primerApellido.hints.tooltip}" id="it14">
                                            <f:validator binding="#{bindings.primerApellido.validator}"/>
                                            <f:validateLength maximum="100"/>
                                        </af:inputText>
                                        <af:inputText value="#{bindings.segundoApellido.inputValue}"
