                                <af:spacer width="10" id="s1"/>
                                <af:link shortDesc="#{resources.PREVIOUS_TASK}"
                                         icon="#{ adfFacesContext.rightToLeft ? '/hw_images/nexttraversalarrow_ena.png'  : '/hw_images/previoustraversalarrow_ena.png'}"
                                         action="fetchPreviousTask"
                                         visible="#{pageFlowScope.enableNavigationButton != null}" id="l1"/>
                                <af:spacer width="10" id="s2"/>
                                <af:link shortDesc="#{resources.NEXT_TASK}"
                                         icon="#{ adfFacesContext.rightToLeft ? '/hw_images/previoustraversalarrow_ena.png' : '/hw_images/nexttraversalarrow_ena.png'}"
                                         action="fetchNextTask"
                                         visible="#{pageFlowScope.enableNavigationButton != null}" id="l2"/>
                                <af:spacer width="10" id="s3"/>
                                <af:link shortDesc="#{resources.SHORT_DESC_CLOSE}" icon="/hw_images/close_ena.png"
                                         action="closeTaskFlow"
                                         visible="#{pageFlowScope.enableNavigationButton != null}" id="l3"/>
                            </af:toolbar>
                        </f:facet>
                        <f:facet name="context"/>
                        <af:panelGroupLayout layout="vertical" id="pgl4">
                            <f:facet name="separator">
                                <af:spacer width="15" height="15" id="s4"/>
                            </f:facet>
                            <af:showDetailHeader size="2" id="dtHead" text="#{resources.DETAILS}"
                                                 shortDesc="#{resources.TASK_HEADER}"
                                                 icon="/hw_images/singleapprover_35x35.png"
                                                 disclosed="#{actionAvailable.discloseHeader}">
                                <f:facet name="context">
                                    <af:link icon="/hw_images/info.png" id="button" clientComponent="true"
                                             rendered="#{!empty bindings.activityId.inputValue}">
                                        <af:showPopupBehavior popupId="helpPopup" align="afterEnd" alignId="button"/>
                                    </af:link>
                                </f:facet>
                                <f:facet name="toolbar"/>
                                <!--trh:tableLayout id="detailTableLayout" width="98%">
                        <trh:rowLayout>
                            <trh:cellFormat width="50%" valign="top"-->
                                <af:panelFormLayout maxColumns="2" rows="4" id="pfl1">
                                    <af:switcher facetName="#{bindings.taskViewContext == 'FYI'}" id="s5">
                                        <f:facet name="false">
                                            <af:panelLabelAndMessage id="assignees" label="#{resources.ASSIGNEES}">
                                                <af:iterator var="assignees" varStatus="varS"
                                                             value="#{bindings.assignees.collectionModel}" id="i1">
                                                    <af:switcher facetName="#{varS.index == 0}" id="s6">
                                                        <f:facet name="false">
                                                            <af:outputText value=", " id="ot1"/>
                                                        </f:facet>
                                                    </af:switcher>
                                                    <af:switcher facetName="#{!empty assignees.displayName}" id="s7">
                                                        <f:facet name="true">
                                                            <af:outputText value="#{assignees.displayName}" id="ot2"/>
                                                        </f:facet>
                                                        <f:facet name="false">
                                                            <af:outputText value="#{assignees.id}" id="ot3"/>
                                                        </f:facet>
                                                    </af:switcher>
                                                </af:iterator>
                                            </af:panelLabelAndMessage>
                                        </f:facet>
                                    </af:switcher>
                                    <af:panelLabelAndMessage id="creator" label="#{resources.CREATOR}">
                                        <af:outputText value="#{bindings.creatorDisplayName.inputValue}" id="ot4"/>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="createdDate" label="#{resources.CREATE_DATE}">
                                        <af:outputText value="#{bindings.createdDate.inputValue}" noWrap="true"
                                                       id="ot5">
                                            <f:convertDateTime type="#{pageFlowScope.dt}" timeZone="#{pageFlowScope.tz}"
                                                               dateStyle="#{pageFlowScope.df}"
                                                               timeStyle="#{pageFlowScope.tf}"
                                                               pattern="#{pageFlowScope.dateTimePattern}"/>
                                        </af:outputText>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="updatedDate" label="#{resources.UPDATE_DATE}">
                                        <af:outputText value="#{bindings.updatedDate.inputValue}" noWrap="true"
                                                       id="ot6">
                                            <f:convertDateTime type="#{pageFlowScope.dt}" timeZone="#{pageFlowScope.tz}"
                                                               dateStyle="#{pageFlowScope.df}"
                                                               timeStyle="#{pageFlowScope.tf}"
                                                               pattern="#{pageFlowScope.dateTimePattern}"/>
                                        </af:outputText>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="expirationDate" label="#{resources.EXPIRATION_DATE}">
                                        <af:outputText value="#{bindings.expirationDate.inputValue}" id="ot7">
                                            <f:convertDateTime type="#{pageFlowScope.dt}" timeZone="#{pageFlowScope.tz}"
                                                               dateStyle="#{pageFlowScope.df}"
                                                               timeStyle="#{pageFlowScope.tf}"
                                                               pattern="#{pageFlowScope.dateTimePattern}"/>
                                        </af:outputText>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="acquiredBy" label="#{resources.ACQUIRED_BY}">
                                        <af:switcher facetName="#{!empty bindings.acquiredByDisplayName.inputValue}"
                                                     id="s8">
                                            <f:facet name="true">
                                                <af:outputText value="#{bindings.acquiredByDisplayName.inputValue}"
                                                               id="ot8"/>
                                            </f:facet>
                                            <f:facet name="false">
                                                <af:outputText value="#{bindings.acquiredBy.inputValue}" id="ot9"/>
                                            </f:facet>
                                        </af:switcher>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="dueDate" label="#{resources.DUE_DATE}"
                                                             rendered="#{!empty bindings.dueDate.inputValue}">
                                        <af:outputText value="#{bindings.dueDate.inputValue}" noWrap="true" id="ot10">
                                            <f:convertDateTime type="#{pageFlowScope.dt}" timeZone="#{pageFlowScope.tz}"
                                                               dateStyle="#{pageFlowScope.df}"
                                                               timeStyle="#{pageFlowScope.tf}"
                                                               pattern="#{pageFlowScope.dateTimePattern}"/>
                                        </af:outputText>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="outcome" label="#{resources.OUTCOME}"
                                                             rendered="#{!empty bindings.actionDisplayName.inputValue}">
                                        <af:outputText value="#{bindings.actionDisplayName.inputValue}" id="ot11"/>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="taskNumber" label="#{resources.TASK_NUMBER}">
                                        <af:outputText value="#{bindings.taskNumber.inputValue}" id="ot12"/>
                                    </af:panelLabelAndMessage>
                                    <af:inputText id="priority" value="#{bindings.priority.inputValue}"
                                                  label="#{resources.PRIORITY}"
                                                  required="#{bindings.priority.mandatory}" columns="3"
                                                  validator="#{actionAvailable.validatePriorityValue}"/>
                                    <af:panelLabelAndMessage id="state" label="#{resources.STATE}">
                                        <af:outputText value="#{resources[bindings.state.inputValue]}" id="ot13"/>
                                    </af:panelLabelAndMessage>
                                </af:panelFormLayout>
                                <!--/trh:cellFormat>
                            <trh:cellFormat>
                                <af:spacer width="15" height="15"/>
                            </trh:cellFormat>
                            <trh:cellFormat width="50%" valign="top">
                                <af:panelFormLayout>
                                    <f:facet name="footer"/>
                                </af:panelFormLayout>
                            </trh:cellFormat>
                        </trh:rowLayout>
                    </trh:tableLayout-->
                            </af:showDetailHeader>
                            <af:showDetailHeader size="2" id="apCntHd" text="#{resources.CONTENTS}"
                                                 disclosed="#{actionAvailable.discloseContents}">
                                <af:panelGroupLayout id="plPnl76" layout="vertical" shortDesc="#{resources.CONTENTS}">
                                    <af:panelBox text="General" id="pb2">
                                        <af:panelGroupLayout id="pgl23" layout="horizontal">
                                            <af:panelFormLayout id="pfl2"
                                                                visible="#{bindings.nroRadicado.inputValue != null}">
                                                <af:inputText label="No. radicado"
                                                              value="#{bindings.nroRadicado.inputValue}" id="it50"
                                                              readOnly="true"/>
                                                <af:inputText label="Tiempo Respuesta"
                                                              value="#{bindings.tiempoRespuestaBO.inputValue} (D&#237;as H&#225;biles)"
                                                              id="it1" readOnly="true"/>
                                            </af:panelFormLayout>
                                            <af:panelFormLayout id="pfl20">
                                                <af:inputText label="Fecha radicaci&#243;n"
                                                              value="#{bindings.fechaRadicacion.inputValue}" id="it4"
                                                              readOnly="true">
                                                    <f:convertDateTime type="#{pageFlowScope.dt}"
                                                                       timeZone="#{pageFlowScope.tz}"
                                                                       dateStyle="#{pageFlowScope.df}"
                                                                       timeStyle="#{pageFlowScope.tf}"
                                                                       pattern="#{pageFlowScope.dateTimePattern}"/>
                                                </af:inputText>
                                                <af:inputText label="Fecha vencimiento"
                                                              value="#{bindings.vencimiento.inputValue}" id="it16"
                                                              readOnly="true">
                                                    <f:convertDateTime type="#{pageFlowScope.dt}"
                                                                       timeZone="#{pageFlowScope.tz}"
                                                                       dateStyle="#{pageFlowScope.df}"
                                                                       timeStyle="#{pageFlowScope.tf}"
                                                                       pattern="#{pageFlowScope.dateTimePattern}"/>
                                                </af:inputText>
                                                <!--af:inputText value="#{bindings.vencimiento.inputValue}"
                                                              label="#{bindings.vencimiento.hints.label}"
                                                              required="#{bindings.vencimiento.hints.mandatory}"
                                                              columns="#{bindings.vencimiento.hints.displayWidth}"
                                                              maximumLength="#{bindings.vencimiento.hints.precision}"
                                                              shortDesc="#{bindings.vencimiento.hints.tooltip}"
                                                              id="it4">
                                                    <f:validator binding="#{bindings.vencimiento.validator}"/>
                                                    <af:convertDateTime pattern="#{bindings.vencimiento.format}"/>
                                                </af:inputText-->
                                            </af:panelFormLayout>
                                            <af:panelFormLayout id="pfl4">
                                                <af:inputText value="#{bindings.creatorDisplayName.inputValue}" id="it8"
                                                              readOnly="true" label="Creador"/>
                                                <af:inputText value="#{bindings.updatedDate.inputValue}" id="it10"
                                                              readOnly="true" label="Actualizado">
                                                    <f:convertDateTime type="#{pageFlowScope.dt}"
                                                                       timeZone="#{pageFlowScope.tz}"
                                                                       dateStyle="#{pageFlowScope.df}"
                                                                       timeStyle="#{pageFlowScope.tf}"
                                                                       pattern="#{pageFlowScope.dateTimePattern}"/>
                                                </af:inputText>
                                                <af:inputText label="Dependencia"
                                                              value="#{operacionBean.anmUnidad.nombreUnidadadministrativa}"
                                                              id="ot15" visible="false"/>
                                            </af:panelFormLayout>
                                        </af:panelGroupLayout>
                                    </af:panelBox>
                                    <af:panelBox text="Remitente - Interesado" id="pb3">
                                        <af:panelFormLayout id="pfl8">
                                            <af:inputText value="#{bindings.tipoIdentificacion.inputValue}"
                                                          simple="false"
                                                          columns="#{bindings.tipoIdentificacion.hints.displayWidth}"
                                                          maximumLength="#{bindings.tipoIdentificacion.hints.precision}"
                                                          shortDesc="#{bindings.tipoIdentificacion.hints.tooltip}"
                                                          label="Tipo identificaci&#243;n" readOnly="true" id="it5">
                                                <f:validator binding="#{bindings.numeroIdentificacion.validator}"/>
                                            </af:inputText>
                                            <af:inputText value="#{bindings.numeroIdentificacion.inputValue}"
                                                          simple="false"
                                                          columns="#{bindings.numeroIdentificacion.hints.displayWidth}"
                                                          maximumLength="#{bindings.numeroIdentificacion.hints.precision}"
                                                          shortDesc="#{bindings.numeroIdentificacion.hints.tooltip}"
                                                          label="No. Identificaci&#243;n" readOnly="true" id="it3">
                                                <f:validator binding="#{bindings.numeroIdentificacion.validator}"/>
                                            </af:inputText>
                                            <af:inputText value="#{bindings.primerNombre.inputValue} #{bindings.segundoNombre.inputValue}"
                                                          simple="false" readOnly="true" label="Nombre(s)" id="it9">
                                                <f:validator binding="#{bindings.nombre.validator}"/>
                                            </af:inputText>
                                            <af:inputText label="Apellido(s)" id="it33" readOnly="true"
                                                          value="#{bindings.primerApellido.inputValue} #{bindings.segundoApellido.inputValue}"/>
                                            <af:inputText value="#{bindings.email2.inputValue}"
                                                          label="#{bindings.email2.hints.label}"
                                                          required="#{bindings.email2.hints.mandatory}"
                                                          columns="#{bindings.email2.hints.displayWidth}"
                                                          maximumLength="#{bindings.email2.hints.precision}"
                                                          shortDesc="#{bindings.email2.hints.tooltip}" readOnly="true"
                                                          id="it2">
                                                <f:validator binding="#{bindings.email2.validator}"/>
                                            </af:inputText>
                                            <af:inputText value="#{bindings.telefono1.inputValue}" simple="false"
                                                          readOnly="true"
                                                          columns="#{bindings.telefono1.hints.displayWidth}"
                                                          maximumLength="#{bindings.telefono1.hints.precision}"
                                                          shortDesc="#{bindings.telefono1.hints.tooltip}"
                                                          label="Tel&#233;fono" id="it17">
                                                <f:validator binding="#{bindings.telefono1.validator}"/>
                                            </af:inputText>
                                            <af:inputText value="#{bindings.celular.inputValue}" simple="false"
                                                          readOnly="true"
                                                          columns="#{bindings.celular.hints.displayWidth}"
                                                          maximumLength="#{bindings.celular.hints.precision}"
                                                          shortDesc="#{bindings.celular.hints.tooltip}" label="Celular"
                                                          id="it7">
                                                <f:validator binding="#{bindings.celular.validator}"/>
                                            </af:inputText>
                                            <af:inputText value="#{bindings.direccion.inputValue}" simple="false"
                                                          readOnly="true"
                                                          columns="#{bindings.direccion.hints.displayWidth}"
                                                          maximumLength="#{bindings.direccion.hints.precision}"
                                                          shortDesc="#{bindings.direccion.hints.tooltip}"
                                                          label="Direcci&#243;n" id="it21">
                                                <f:validator binding="#{bindings.direccion.validator}"/>
                                            </af:inputText>
                                            <af:selectOneChoice value="#{bindings.idPais.inputValue}" label="Pa&#237;s"
                                                                id="socPais" readOnly="true"
                                                                contentStyle="margin-top:8px;">
                                                <f:selectItems value="#{operacionBean.lstPais2}" id="si9"/>
                                            </af:selectOneChoice>
                                            <af:selectOneChoice value="#{bindings.idDepartamento.inputValue}"
                                                                visible="#{bindings.idPais.inputValue eq 52}"
                                                                readOnly="true" label="Departamento" id="socDpto"
                                                                contentStyle="margin-top:8px;">
                                                <f:selectItems value="#{operacionBean.lstDepartamento2}" id="si15"/>
                                            </af:selectOneChoice>
                                            <af:inputText label="Ciudad/Municipio" id="it38" readOnly="true"
                                                          visible="#{bindings.idPais.inputValue eq 52}"
                                                          value="#{bindings.ciudad.inputValue}"/>
                                        </af:panelFormLayout>
                                    </af:panelBox>
                                    <af:panelBox text="Contenido" id="pb4">
                                        <af:inputText label="Asunto" id="it39" readOnly="true"
                                                      value="#{bindings.asunto.inputValue}"/>
                                        <af:panelGroupLayout layout="horizontal" id="pgl24" valign="top">
                                            <af:panelFormLayout id="pfl15">
                                                <af:selectBooleanCheckbox id="sbcExp" autoSubmit="true"
                                                                          label="&#191;Expediente Minero?"
                                                                          value="#{bindings.esTituloMinero.inputValue}"
                                                                          valueChangeListener="#{operacionBean.cambiarExpMinero}"/>
                                                <af:inputText value="#{bindings.placa.inputValue}" simple="false"
                                                              required="#{bindings.placa.hints.mandatory}"
                                                              autoSubmit="true"
                                                              columns="#{bindings.placa.hints.displayWidth}"
                                                              maximumLength="100"
                                                              shortDesc="#{bindings.placa.hints.tooltip}"
                                                              placeholder="Placa" id="it26" partialTriggers="sbcExp"
                                                              binding="#{operacionBean.itPlaca}" label="Nro.Placa"
                                                              disabled="#{not bindings.esTituloMinero.inputValue}"
                                                              valueChangeListener="#{operacionBean.cambiarPlaca}">
                                                    <f:validateLength maximum="100"/>
                                                </af:inputText>
                                                <af:inputText label="Referencia" id="it41" readOnly="true"
                                                              value="#{bindings.referencia.inputValue}"/>
                                                <af:inputText label="Nro.folios" id="it11" readOnly="false"
                                                              value="#{bindings.nroFolios.inputValue}"
                                                              maximumLength="4">
                                                    <f:validateLongRange minimum="1" maximum="9999"/>
                                                </af:inputText>
                                            </af:panelFormLayout>
                                            <af:panelFormLayout id="pfl16">
                                                <af:selectBooleanCheckbox value="#{bindings.esPqrsBO.inputValue}"
                                                                          label="&#191;PQRS?" id="socEsPqrs"
                                                                          valueChangeListener="#{operacionBean.cambiarEsPqrs}"
                                                                          autoSubmit="true"/>
                                                <af:spacer width="10" height="10" id="s10"/>
                                                <af:selectOneChoice label="Tipo PQRS" id="socTipoPqrs"
                                                                    partialTriggers="socEsPqrs"
                                                                    value="#{bindings.tipoPqrsBO.inputValue}"
                                                                    disabled="#{bindings.esPqrsBO.inputValue == null or bindings.esPqrsBO.inputValue eq 'false'}"
                                                                    autoSubmit="true" showRequired="true"
                                                                    valueChangeListener="#{operacionBean.cambiarTipoPqrsGestion}">
                                                    <f:selectItems value="#{operacionBean.lstTipoSolicitud}" id="si10"/>
                                                </af:selectOneChoice>
                                                <af:inputText value="#{bindings.nombreTipoPQRS.inputValue}"
                                                              label="#{bindings.nombreTipoPQRS.hints.label}"
                                                              visible="false"
                                                              required="#{bindings.nombreTipoPQRS.hints.mandatory}"
                                                              columns="#{bindings.nombreTipoPQRS.hints.displayWidth}"
                                                              maximumLength="#{bindings.nombreTipoPQRS.hints.precision}"
                                                              shortDesc="#{bindings.nombreTipoPQRS.hints.tooltip}"
                                                              id="it6">
                                                    <f:validator binding="#{bindings.nombreTipoPQRS.validator}"/>
                                                </af:inputText>
                                                <af:spacer width="10" height="10" id="s11"/>
                                                <af:selectOneChoice label="&#191;Requiere respuesta?" id="socReqResp"
                                                                    value="#{bindings.requiereRespuestaDO.inputValue}"
                                                                    autoSubmit="true"
                                                                    valueChangeListener="#{operacionBean.cambiarReqRespuesta}"
                                                                    binding="#{operacionBean.socReqRespuesta}"
                                                                    showRequired="true"
                                                                    disabled="#{bindings.esPqrsBO.inputValue eq 'true'}"
                                                                    partialTriggers="socEsPqrs">
