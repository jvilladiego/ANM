<?xml version="1.0" encoding="windows-1252" ?>
<persistence xmlns="http://java.sun.com/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="http://java.sun.com/xml/ns/persistence http://java.sun.com/xml/ns/persistence/persistence_1_0.xsd"
             version="1.0">
  <persistence-unit name="ComunicacionesBpmViewPrj">
    <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>
    <jta-data-source>jdbc/ComunicacionesDS</jta-data-source>
    <class>co.gov.anm.comunicaciones.entity.SgdUsuarioRol</class>
    <class>co.gov.anm.comunicaciones.entity.SgdRol</class>
    <class>co.gov.anm.comunicaciones.entity.SgdUsuario</class>
    <class>co.gov.anm.comunicaciones.entity.AnmPlantilla</class>
    <properties>
      <property name="eclipselink.target-server" value="WebLogic_10"/>
      <property name="javax.persistence.jtaDataSource" value="jdbc/ComunicacionesDS"/>
    </properties>
  </persistence-unit>
  <persistence-unit name="WCContent">
    <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>
    <jta-data-source>jdbc/WCCConnectionDS</jta-data-source>
    <class>co.gov.anm.comunicaciones.entity.Cuenta</class>
    <class>co.gov.anm.comunicaciones.entity.Folders</class>
    <class>co.gov.anm.comunicaciones.entity.TipoDocumentalTramite</class>
    <class>co.gov.anm.comunicaciones.entity.Tramite</class>
    <properties>
      <property name="eclipselink.target-server" value="WebLogic_10"/>
      <property name="javax.persistence.jtaDataSource" value="jdbc/WCCConnectionDS"/>
    </properties>
  </persistence-unit>  
</persistence>
