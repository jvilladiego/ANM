                                                    <af:button textAndAccessKey="#{resources.OK_AK}"
                                                               actionListener="#{bindings.Delete2.execute}"
                                                               immediate="true" partialSubmit="true" id="delAtOK"
                                                               action="#{popupBean.hideAttachmentDeleteDialog}"/>
                                                    <af:button textAndAccessKey="#{resources.CANCEL_AK}" id="delAtCan"
                                                               action="#{popupBean.hideAttachmentDeleteDialog}"
                                                               partialSubmit="true"/>
                                                </af:panelGroupLayout>
                                            </f:facet>
                                            <af:panelGroupLayout id="pgl11">
                                                <af:panelFormLayout id="pfl10">
                                                    <af:outputText id="delAttTxt"
                                                                   value="#{resources.DELETE_ATTACHMENT_MSG}"/>
                                                </af:panelFormLayout>
                                            </af:panelGroupLayout>
                                        </af:dialog>
                                    </af:popup>
                                </af:panelGroupLayout>
                                
                            </af:showDetailHeader>
                        </af:panelGroupLayout>
                    </af:panelHeader>
                    <f:facet name="separator"/>
                </af:panelGroupLayout>
            </af:form>
        </af:document>
    </f:view>
</jsp:root>