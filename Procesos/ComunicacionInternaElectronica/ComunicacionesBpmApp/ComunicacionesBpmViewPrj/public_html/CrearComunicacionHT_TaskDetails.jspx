<?xml version='1.0' encoding='UTF-8'?>
<jsp:root xmlns:jsp="http://java.sun.com/JSP/Page" version="2.1" xmlns:f="http://java.sun.com/jsf/core"
          xmlns:af="http://xmlns.oracle.com/adf/faces/rich">
    <jsp:directive.page contentType="text/html;charset=UTF-8"/>
    <f:view xmlns:c="http://java.sun.com/jsp/jstl/core" xmlns:trh="http://myfaces.apache.org/trinidad/html"
            xmlns:wf="http://xmlns.oracle.com/bpel/workflow/workflow-taglib.tld"
            xmlns:wlc="http://xmlns.oracle.com/bpel/workflow/worklist">
        <af:document title="CrearComunicacionHT_TaskDetails.jspx" id="d1">
            <af:messages id="m1"/>
            <af:resource type="javascript" source="/jsLibs/taskDetails.js"/>
            <af:resource type="javascript" source="/jsLibs/commonBPM.js"/>
            <af:form id="f1" usesUpload="true">
                <af:panelGroupLayout layout="vertical" inlineStyle="padding: 5px;" id="pgl8">
                    <af:panelHeader text="#{bindings.title.inputValue}" id="ph1">
                        <f:facet name="info"/>
                        <f:facet name="legend"/>
                        <f:facet name="menuBar"/>
                        <f:facet name="toolbar">
                            <af:toolbar visible="#{actionAvailable.toolbarAvailable}" id="t4">
                                <af:switcher id="customActionButtons"
                                             facetName="#{actionAvailable.isCustomActionButtons}">
                                    <f:facet name="true">
                                        <af:panelGroupLayout layout="horizontal" id="pgl26">
                                            <af:button actionListener="#{CrearComunicacionJSFBean.crearComunicacion}"
                                                       text="#{wf:getResourceValue('SUBMIT', 'bindings.customActions')}"
                                                       disabled="#{!bindings.SUBMIT.enabled}"
                                                       action="#{invokeActionBean.invokeOperation}"
                                                       partialSubmit="false"
                                                       visible="#{wf:isCustomActionAvailable('SUBMIT', 'bindings.customActions')}"
                                                       id="b2">
                                                <f:attribute name="DC_OPERATION_BINDING" value="bindings.SUBMIT"/>
                                            </af:button>
                                        </af:panelGroupLayout>
                                    </f:facet>
                                </af:switcher>
                                <af:button actionListener="#{invokeActionBean.setOperation}" text="#{resources.CLAIM}"
                                           id="Claim" action="#{invokeActionBean.invokeOperation}" partialSubmit="false"
                                           visible="#{actionAvailable.claimAvailable}">
                                    <f:attribute name="DC_OPERATION_BINDING" value="bindings.Claim"/>
                                </af:button>
                                <af:button id="acknowledge" actionListener="#{invokeActionBean.setOperation}"
                                           text="#{resources.ACKNOWLEDGE}" action="#{invokeActionBean.invokeOperation}"
                                           partialSubmit="false" visible="#{actionAvailable.isFyiTask}">
                                    <f:attribute name="DC_OPERATION_BINDING" value="bindings.Acknowledge"/>
                                </af:button>
                                <af:button id="resume" actionListener="#{invokeActionBean.setOperation}"
                                           text="#{resources.RESUME}" action="#{invokeActionBean.invokeOperation}"
                                           partialSubmit="false" visible="#{actionAvailable.resumeAvailable}">
                                    <f:attribute name="DC_OPERATION_BINDING" value="bindings.Resume"/>
                                </af:button>
                                <af:panelGroupLayout layout="horizontal" id="pgl29" visible="false">
                                    <af:group rendered="#{!((empty actionAvailable.customActions) and (empty actionAvailable.redirectActions) and (empty actionAvailable.otherActions)) || bindings.update.enabled}"
                                              id="g4">
                                        <af:menuBar id="mb1">
                                            <af:menu id="acts" text="#{resources.TASK_ACTIONS}"
                                                     visible="#{actionAvailable.actionsAvailable || bindings.update.enabled}">
                                                <af:group id="g1">
                                                    <af:forEach var="childNode1"
                                                                items="#{actionAvailable.customActions}">
                                                        <af:commandMenuItem textAndAccessKey="#{childNode1.displayName}"
                                                                            actionListener="#{invokeActionBean.setAction}"
                                                                            action="#{invokeActionBean.action}"
                                                                            partialSubmit="false" id="cmi2">
                                                            <f:attribute name="ACTION_MENU_ITEM"
                                                                         value="#{childNode1.action}"/>
                                                        </af:commandMenuItem>
                                                    </af:forEach>
                                                </af:group>
                                                <af:group id="g3">
                                                    <af:forEach var="childNode2"
                                                                items="#{actionAvailable.redirectActions}">
                                                        <af:commandMenuItem textAndAccessKey="#{resources[childNode2]}"
                                                                            actionListener="#{invokeActionBean.setAction}"
                                                                            action="#{invokeActionBean.action}"
                                                                            partialSubmit="true" id="cmi1">
                                                            <f:attribute name="ACTION_MENU_ITEM" value="#{childNode2}"/>
                                                        </af:commandMenuItem>
                                                    </af:forEach>
                                                </af:group>
                                                <af:group id="g5">
                                                    <af:forEach var="childNode3"
                                                                items="#{actionAvailable.otherActions}">
                                                        <af:commandMenuItem textAndAccessKey="#{resources[childNode3]}"
                                                                            actionListener="#{invokeActionBean.setAction}"
                                                                            action="#{invokeActionBean.action}"
                                                                            partialSubmit="false" id="cmi4">
                                                            <f:attribute name="ACTION_MENU_ITEM" value="#{childNode3}"/>
                                                        </af:commandMenuItem>
                                                    </af:forEach>
                                                </af:group>
                                                <af:group id="g6">
                                                    <af:commandMenuItem id="save" textAndAccessKey="#{resources.SAVE}"
                                                                        actionListener="#{invokeActionBean.setAction}"
                                                                        action="#{invokeActionBean.action}"
                                                                        partialSubmit="false"
                                                                        rendered="#{actionAvailable.updateAvailable}">
                                                        <f:attribute name="ACTION_MENU_ITEM" value="bindings.update"/>
                                                    </af:commandMenuItem>
                                                </af:group>
                                            </af:menu>
                                        </af:menuBar>
                                    </af:group>
                                </af:panelGroupLayout>
                                <af:spacer width="10" id="s2"/>
                                <af:link shortDesc="#{resources.PREVIOUS_TASK}"
                                         icon="#{ adfFacesContext.rightToLeft ? '/hw_images/nexttraversalarrow_ena.png'  : '/hw_images/previoustraversalarrow_ena.png'}"
                                         action="fetchPreviousTask"
                                         visible="#{pageFlowScope.enableNavigationButton != null}" id="l2"/>
                                <af:spacer width="10" id="s3"/>
                                <af:link shortDesc="#{resources.NEXT_TASK}"
                                         icon="#{ adfFacesContext.rightToLeft ? '/hw_images/previoustraversalarrow_ena.png' : '/hw_images/nexttraversalarrow_ena.png'}"
                                         action="fetchNextTask"
                                         visible="#{pageFlowScope.enableNavigationButton != null}" id="l3"/>
                                <af:spacer width="10" id="s19"/>
                                <af:link shortDesc="#{resources.SHORT_DESC_CLOSE}" icon="/hw_images/close_ena.png"
                                         action="closeTaskFlow"
                                         visible="#{pageFlowScope.enableNavigationButton != null}" id="l1"/>
                            </af:toolbar>
                        </f:facet>
                        <f:facet name="context"/>
                        <af:panelGroupLayout layout="vertical" id="pgl16">
                            <f:facet name="separator">
                                <af:spacer width="15" height="15" id="s6"/>
                            </f:facet>
                            <af:showDetailHeader size="2" id="dtHead" text="#{resources.DETAILS}"
                                                 shortDesc="#{resources.TASK_HEADER}"
                                                 icon="/hw_images/singleapprover_35x35.png"
                                                 disclosed="#{actionAvailable.discloseHeader}">
                                <f:facet name="toolbar"/>
                                <af:panelFormLayout maxColumns="2" rows="4" id="pfl12">
                                    <af:switcher facetName="#{bindings.taskViewContext == 'FYI'}" id="s1">
                                        <f:facet name="false">
                                            <af:panelLabelAndMessage id="assignees" label="#{resources.ASSIGNEES}">
                                                <af:iterator var="assignees" varStatus="varS"
                                                             value="#{bindings.assignees.collectionModel}" id="i2">
                                                    <af:switcher facetName="#{varS.index == 0}" id="s7">
                                                        <f:facet name="false">
                                                            <af:outputText value=", " id="ot20"/>
                                                        </f:facet>
                                                    </af:switcher>
                                                    <af:switcher facetName="#{!empty assignees.displayName}" id="s12">
                                                        <f:facet name="true">
                                                            <af:outputText value="#{assignees.displayName}" id="ot19"/>
                                                        </f:facet>
                                                        <f:facet name="false">
                                                            <af:outputText value="#{assignees.id}" id="ot5"/>
                                                        </f:facet>
                                                    </af:switcher>
                                                </af:iterator>
                                            </af:panelLabelAndMessage>
                                        </f:facet>
                                    </af:switcher>
                                    <af:panelLabelAndMessage id="creator" label="#{resources.CREATOR}">
                                        <af:outputText value="#{bindings.creatorDisplayName.inputValue}" id="ot14"/>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="createdDate" label="#{resources.CREATE_DATE}">
                                        <af:outputText value="#{bindings.createdDate.inputValue}" noWrap="true"
                                                       id="ot17">
                                            <f:convertDateTime type="#{pageFlowScope.dt}" timeZone="#{pageFlowScope.tz}"
                                                               dateStyle="#{pageFlowScope.df}"
                                                               timeStyle="#{pageFlowScope.tf}"
                                                               pattern="#{pageFlowScope.dateTimePattern}"/>
                                        </af:outputText>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="updatedDate" label="#{resources.UPDATE_DATE}">
                                        <af:outputText value="#{bindings.updatedDate.inputValue}" noWrap="true"
                                                       id="ot18">
                                            <f:convertDateTime type="#{pageFlowScope.dt}" timeZone="#{pageFlowScope.tz}"
                                                               dateStyle="#{pageFlowScope.df}"
                                                               timeStyle="#{pageFlowScope.tf}"
                                                               pattern="#{pageFlowScope.dateTimePattern}"/>
                                        </af:outputText>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="expirationDate" label="#{resources.EXPIRATION_DATE}">
                                        <af:outputText value="#{bindings.expirationDate.inputValue}" id="ot25">
                                            <f:convertDateTime type="#{pageFlowScope.dt}" timeZone="#{pageFlowScope.tz}"
                                                               dateStyle="#{pageFlowScope.df}"
                                                               timeStyle="#{pageFlowScope.tf}"
                                                               pattern="#{pageFlowScope.dateTimePattern}"/>
                                        </af:outputText>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="acquiredBy" label="#{resources.ACQUIRED_BY}">
                                        <af:switcher facetName="#{!empty bindings.acquiredByDisplayName.inputValue}"
                                                     id="s8">
                                            <f:facet name="true">
                                                <af:outputText value="#{bindings.acquiredByDisplayName.inputValue}"
                                                               id="ot28"/>
                                            </f:facet>
                                            <f:facet name="false">
                                                <af:outputText value="#{bindings.acquiredBy.inputValue}" id="ot27"/>
                                            </f:facet>
                                        </af:switcher>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="dueDate" label="#{resources.DUE_DATE}"
                                                             rendered="#{!empty bindings.dueDate.inputValue}">
                                        <af:outputText value="#{bindings.dueDate.inputValue}" noWrap="true" id="ot13">
                                            <f:convertDateTime type="#{pageFlowScope.dt}" timeZone="#{pageFlowScope.tz}"
                                                               dateStyle="#{pageFlowScope.df}"
                                                               timeStyle="#{pageFlowScope.tf}"
                                                               pattern="#{pageFlowScope.dateTimePattern}"/>
                                        </af:outputText>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="outcome" label="#{resources.OUTCOME}"
                                                             rendered="#{!empty bindings.actionDisplayName.inputValue}">
                                        <af:outputText value="#{bindings.actionDisplayName.inputValue}" id="ot9"/>
                                    </af:panelLabelAndMessage>
                                    <af:panelLabelAndMessage id="taskNumber" label="#{resources.TASK_NUMBER}">
                                        <af:outputText value="#{bindings.taskNumber.inputValue}" id="ot23"/>
                                    </af:panelLabelAndMessage>
                                    <af:inputText id="priority" value="#{bindings.priority.inputValue}"
                                                  label="#{resources.PRIORITY}"
                                                  required="#{bindings.priority.mandatory}" columns="3"
                                                  validator="#{actionAvailable.validatePriorityValue}"/>
                                    <af:panelLabelAndMessage id="state" label="#{resources.STATE}">
                                        <af:outputText value="#{resources[bindings.state.inputValue]}" id="ot16"/>
                                    </af:panelLabelAndMessage>
                                </af:panelFormLayout>
                            </af:showDetailHeader>
                            <af:showDetailHeader size="2" id="apCntHd" text="#{resources.CONTENTS}"
                                                 disclosed="#{actionAvailable.discloseContents}">
                                <af:panelBox id="idPlantiilas" text="Plantillas">
                                    <af:panelGroupLayout id="pfl3">
                                        <af:table var="row" rowBandingInterval="1" id="t5" rowSelection="single"
                                                  value="#{CrearComunicacionJSFBean.plantillasSet}"
                                                  styleClass="AFStretchWidth">
                                            <af:column sortable="false" headerText="Nombre plantilla" id="c3"
                                                       width="300">
                                                <af:link text="#{row.nombre}" id="l4" targetFrame="_blank"
                                                         destination="#{row.ruta}"/>
                                            </af:column>
                                            <af:column sortable="false" headerText="Fecha creaci&#243;n" id="c4"
                                                       width="100">
                                                <af:outputText value="#{row.fechaCreacion}" id="ot24"/>
                                            </af:column>
                                        </af:table>
                                    </af:panelGroupLayout>
                                </af:panelBox>
                                <af:panelBox id="idPanelGestion" text="Comunicaci&#243;n">
                                  
                                    <af:panelFormLayout id="panelFormLayout3" rows="5" maxColumns="2"
                                                        styleClass="p_AFClickToEdit" >
                                         <af:inputText value="#{bindings.asunto.inputValue}" simple="false"
                                                      required="true" columns="50" label="Asunto"
                                                      maximumLength="500"
                                                      shortDesc="#{bindings.asunto.hints.tooltip}" id="it2">
                                            <f:validateLength maximum="500"/>
                                        </af:inputText>
                                        <af:selectOneChoice value="#{bindings.idAsignacion.inputValue}" label="Enviar a"
                                                            immediate="false" autoSubmit="true" required="true"
                                                            valueChangeListener="#{CrearComunicacionJSFBean.cambiarAsignacion}"
                                                            id="soc13" >
                                            <f:selectItem itemLabel="Seleccione" itemValue="-1" id="selAsgn"/>
                                            <f:selectItems value="#{CrearComunicacionJSFBean.listaAsignacion}"
                                                           id="si13"/>
                                        </af:selectOneChoice>
                                        <af:selectOneChoice disabled="#{bindings.idAsignacion.inputValue=='3'}"
                                                            label="Dependencia Destino" immediate="false"
                                                            autoSubmit="true" 
                                                            valueChangeListener="#{CrearComunicacionJSFBean.cambiarDependenciaDestino}"
                                                            shortDesc="#{bindings.codDependenciaDestino.hints.tooltip}"
                                                            id="soc1" partialTriggers="soc13">
                                            <f:selectItem itemLabel="Seleccione" itemValue="-1" id="selDep"/>
                                            <f:selectItems value="#{CrearComunicacionJSFBean.dependencias}" id="si10"/>
                                        </af:selectOneChoice>
                                        <af:selectOneChoice value="#{bindings.idUsuarioCom.inputValue}"
                                                            disabled="#{bindings.idAsignacion.inputValue=='2' or bindings.idAsignacion.inputValue=='3'}"
                                                            label="Usuario Destino" immediate="false" autoSubmit="true"
                                                            partialTriggers="soc13 soc1"
                                                            valueChangeListener="#{CrearComunicacionJSFBean.cambiarUsuarioDestino}"
                                                            shortDesc="#{bindings.idUsuarioCom.hints.tooltip}"
                                                            id="soc14">
                                            <f:selectItem itemLabel="Seleccione" id="selUser"/>
                                            <f:selectItems value="#{CrearComunicacionJSFBean.usuariosDependencia}"
                                                           id="si14"/>
                                        </af:selectOneChoice>
                                        <af:selectBooleanCheckbox value="#{bindings.responderComunicacion.inputValue}"
                                                                  simple="false" label="Requiere Respuesta"
                                                                  immediate="false"
                                                                  disabled="#{bindings.idAsignacion.inputValue==null or bindings.idAsignacion.inputValue=='2' or bindings.idAsignacion.inputValue=='3'}"
                                                                  required="#{bindings.responderComunicacion.hints.mandatory}"
                                                                  autoSubmit="true" partialTriggers="soc13"
                                                                  shortDesc="#{bindings.responderComunicacion.hints.tooltip}"
                                                                  valueChangeListener="#{CrearComunicacionJSFBean.cambiarRequiereRespuesta}"
                                                                  id="sbc2"/>
                                        <af:inputNumberSpinbox value="#{bindings.tiempoRespuesta.inputValue}"
                                                               showRequired="true"
                                                               label="Tiempo Respuesta (D&#237;as H&#225;biles)"
                                                               minimum="1" maximum="30" stepSize="1"
                                                               disabled="#{!bindings.responderComunicacion.inputValue}"
                                                               autoSubmit="true" partialTriggers="sbc2" id="ins2"/>
                                        <af:inputText value="#{bindings.referencia.inputValue}" simple="false"
                                                      required="#{bindings.referencia.hints.mandatory}"
                                                      label="Referencia"
                                                      columns="#{bindings.referencia.hints.displayWidth}"
                                                      maximumLength="200"
                                                      shortDesc="#{bindings.referencia.hints.tooltip}" id="it3">
                                            <f:validateLength maximum="200"/>
                                        </af:inputText>
                                        <af:inputText value="#{bindings.nroRadicadoRelacionado.inputValue}"
                                                      simple="false"
                                                      required="#{bindings.nroRadicadoRelacionado.hints.mandatory}"
                                                      label="No. de Radicado Relacionado"
                                                      columns="#{bindings.nroRadicadoRelacionado.hints.displayWidth}"
                                                      maximumLength="100"
                                                      shortDesc="#{bindings.nroRadicadoRelacionado.hints.tooltip}"
                                                      id="it5">
                                            <f:validateLength maximum="100"/>
                                        </af:inputText>
                                        <af:selectBooleanCheckbox value="#{bindings.esTituloMinero.inputValue}"
                                                                  simple="false" label="Expediente Minero Relacionado"
                                                                  clientComponent="true"
                                                                  required="#{bindings.esTituloMinero.hints.mandatory}"
                                                                  shortDesc="#{bindings.esTituloMinero.hints.tooltip}"
                                                                  autoSubmit="true" id="sbcEsTitulo"
                                                                  valueChangeListener="#{CrearComunicacionJSFBean.cambiarEsExpMinero}"/>
                                        <af:inputText value="#{bindings.nroPlaca.inputValue}" simple="false"
                                                      showRequired="true" label="Expediente Minero"
                                                      disabled="#{!bindings.esTituloMinero.inputValue}"
                                                      autoSubmit="true" partialTriggers="sbcEsTitulo" clientComponent="true"
                                                      columns="#{bindings.nroPlaca.hints.displayWidth}"
                                                      maximumLength="100"
                                                      shortDesc="#{bindings.nroPlaca.hints.tooltip}" id="it4"
                                                      valueChangeListener="#{CrearComunicacionJSFBean.validarExpMinero}">
                                            <f:validateLength maximum="100"/>
                                        </af:inputText>
                                    </af:panelFormLayout>
                                </af:panelBox>
                               <af:panelBox id="pbAdjuntos" text="Adjuntos">
                                   <af:panelGroupLayout id="pgl13" layout="vertical">
                                     <af:panelGroupLayout id="pgl14">
                                           <af:inputFile label=" " id="if1" autoSubmit="true" required="true"
                                                    valueChangeListener="#{CrearComunicacionJSFBean.cambiarDocPpal}"
                                                          binding="#{CrearComunicacionJSFBean.ifAnexo}"/>
                                        </af:panelGroupLayout>
                                        <af:spacer width="20" height="20" id="s9"/>
                                        <wlc:manageDocuments docBean="#{pageFlowScope.docMgmtBean}" id="manageDocs"
                                                                 rendered="#{!actionAvailable.inNotificationClient}"/>
                                        <!--<af:inputText value="#{bindings.name1.inputValue}"
                                                      label="#{bindings.name1.hints.label}"
                                                      required="#{bindings.name1.hints.mandatory}"
                                                      columns="#{bindings.name1.hints.displayWidth}"
                                                      maximumLength="#{bindings.name1.hints.precision}"
                                                      shortDesc="#{bindings.name1.hints.tooltip}" id="it9">
                                            <f:validator binding="#{bindings.name1.validator}"/>
                                        </af:inputText>
                                        <af:inputText value="#{bindings.mimeType1.inputValue}"
                                                      label="#{bindings.mimeType1.hints.label}"
                                                      required="#{bindings.mimeType1.hints.mandatory}"
                                                      columns="#{bindings.mimeType1.hints.displayWidth}"
                                                      maximumLength="#{bindings.mimeType1.hints.precision}"
                                                      shortDesc="#{bindings.mimeType1.hints.tooltip}" id="it10">
                                            <f:validator binding="#{bindings.mimeType1.validator}"/>
                                        </af:inputText>
                                        <af:inputText value="#{bindings.content1.inputValue}"
                                                      label="#{bindings.content1.hints.label}"
                                                      required="#{bindings.content1.hints.mandatory}"
                                                      columns="#{bindings.content1.hints.displayWidth}"
                                                      maximumLength="#{bindings.content1.hints.precision}"
                                                      shortDesc="#{bindings.content1.hints.tooltip}" id="it11">
                                            <f:validator binding="#{bindings.content1.validator}"/>
                                        </af:inputText>
                                        <af:inputText value="#{bindings.size.inputValue}"
                                                      label="#{bindings.size.hints.label}"
                                                      required="#{bindings.size.hints.mandatory}"
                                                      columns="#{bindings.size.hints.displayWidth}"
                                                      maximumLength="#{bindings.size.hints.precision}"
                                                      shortDesc="#{bindings.size.hints.tooltip}" id="it12">
                                            <f:validator binding="#{bindings.size.validator}"/>
                                            <af:convertNumber groupingUsed="false" pattern="#{bindings.size.format}"/>
                                        </af:inputText>-->
                                    </af:panelGroupLayout>
                                   
                                </af:panelBox>
                                <!--af:inputText value="#{bindings.instanceId.inputValue}"
                                              label="#{bindings.instanceId.hints.label}"
                                              required="#{bindings.instanceId.hints.mandatory}"
                                              columns="#{bindings.instanceId.hints.displayWidth}"
                                              maximumLength="#{bindings.instanceId.hints.precision}"
                                              shortDesc="#{bindings.instanceId.hints.tooltip}" id="it9">
                                    <f:validator binding="#{bindings.instanceId.validator}"/>
                                </af:inputText-->
                                <af:panelBox id="idPanelTipificar" text="Gestión documental">
                                   
                                            <af:panelFormLayout id="pfl1" partialTriggers="sbcEsTitulo"
                                                        visible="#{!bindings.esTituloMinero.inputValue}">
                                                <af:selectOneChoice value="#{bindings.idCatProceso.inputValue}"
                                                                    label="Categor&#237;a"
                                                                    showRequired="#{!bindings.esTituloMinero.inputValue}"
                                                                    disabled="#{bindings.esTituloMinero.inputValue}"
                                                                    shortDesc="#{bindings.idCatProceso.hints.tooltip}"
                                                                    autoSubmit="true" immediate="false"
                                                                    clientComponent="true"
                                                                    valueChangeListener="#{CrearComunicacionJSFBean.cambiarCategoriaProceso}"
                                                                    partialTriggers="sbcEsTitulo" id="soc3">
                                                    <f:selectItem itemLabel="Seleccione" id="siv1"/>
                                                    <f:selectItems value="#{CrearComunicacionJSFBean.categoriasProceso}"
                                                                   id="si1"/>
                                                </af:selectOneChoice>
                                                <af:selectOneChoice value="#{bindings.idProceso.inputValue}"
                                                                    label="Proceso"
                                                                    showRequired="#{!bindings.esTituloMinero.inputValue}"
                                                                    disabled="#{bindings.esTituloMinero.inputValue}"
                                                                    shortDesc="#{bindings.idProceso.hints.tooltip}"
                                                                    clientComponent="true"
                                                                    valueChangeListener="#{CrearComunicacionJSFBean.cambiarProceso}"
                                                                    autoSubmit="true" partialTriggers="sbcEsTitulo soc3"
                                                                    id="soc4">
                                                    <f:selectItem itemLabel="Seleccione" id="siv2"/>
                                                    <f:selectItems value="#{CrearComunicacionJSFBean.procesos}"
                                                                   id="si3"/>
                                                </af:selectOneChoice>
                                                <af:selectOneChoice value="#{bindings.idSerie.inputValue}" label="Serie"
                                                                    showRequired="#{!bindings.esTituloMinero.inputValue}"
                                                                    disabled="#{bindings.esTituloMinero.inputValue}"
                                                                    shortDesc="#{bindings.idSerie.hints.tooltip}"
                                                                    autoSubmit="true" partialTriggers="sbcEsTitulo soc4 soc3"
                                                                    clientComponent="true"
                                                                    valueChangeListener="#{CrearComunicacionJSFBean.cambiarSerie}"
                                                                    id="soc5">
                                                    <f:selectItem itemLabel="Seleccione" id="siv3"/>
                                                    <f:selectItems value="#{CrearComunicacionJSFBean.series}" id="si5"/>
                                                </af:selectOneChoice>
                                                <af:selectOneChoice value="#{bindings.idSubSerie.inputValue}"
                                                                    label="SubSerie"
                                                                    disabled="#{bindings.esTituloMinero.inputValue}"
                                                                    shortDesc="#{bindings.idSubSerie.hints.tooltip}"
                                                                    autoSubmit="true"
                                                                    partialTriggers="sbcEsTitulo soc5 soc4 soc3"
                                                                    clientComponent="true"
                                                                    valueChangeListener="#{CrearComunicacionJSFBean.cambiarSubSerie}"
                                                                    id="soc6">
                                                    <f:selectItem itemLabel="Seleccione" id="selSSRItm1"/>
                                                    <f:selectItems value="#{CrearComunicacionJSFBean.subseries}"
