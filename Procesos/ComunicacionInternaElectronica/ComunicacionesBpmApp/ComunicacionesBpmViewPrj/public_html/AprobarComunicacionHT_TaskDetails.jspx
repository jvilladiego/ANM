                                </af:panelFormLayout>
                                <af:panelGroupLayout id="pgl19" layout="vertical">
                                     <af:panelGroupLayout id="pgl34">
                                            <af:outputLabel value="Documento Principal" for="downloadLink" id="ol1"/>    
                                            <af:link  text="#{bindings.name1.inputValue}" id="downloadLink" targetFrame="_parent">
                                                <af:fileDownloadActionListener method="#{pageFlowScope.aprobarComunicacionJSFBean.descargar}" />
                                            </af:link>
                                            <af:spacer width="20" height="20" id="s19"/>
                                            <af:inputFile label=" " id="if1" autoSubmit="true" 
                                                    valueChangeListener="#{pageFlowScope.aprobarComunicacionJSFBean.cambiarDocPpal}"
                                                          binding="#{pageFlowScope.aprobarComunicacionJSFBean.ifAnexo}"/>
                                        </af:panelGroupLayout>
                                        <af:spacer width="20" height="20" id="s20"/>
                                         <wlc:manageDocuments docBean="#{pageFlowScope.docMgmtBean}" id="manageDocs"
                                                             rendered="#{!actionAvailable.inNotificationClient and !wf:isCustomActionAvailable('APPROVE', 'bindings.customActions') }"/>
                                   </af:panelGroupLayout>
                             </af:panelBox>
                                <!--af:panelFormLayout id="pfl5">
                                    <af:inputText value="#{bindings.name1.inputValue}"
                                                  label="#{bindings.name1.hints.label}"
                                                  required="#{bindings.name1.hints.mandatory}"
                                                  columns="#{bindings.name1.hints.displayWidth}"
                                                  maximumLength="#{bindings.name1.hints.precision}"
                                                  shortDesc="#{bindings.name1.hints.tooltip}" id="it6">
                                        <f:validator binding="#{bindings.name1.validator}"/>
                                    </af:inputText>
                                    <af:inputText value="#{bindings.content1.inputValue}"
